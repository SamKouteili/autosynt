{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01LAy5axqGfhs9ZDo73cHG79","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FpPm5jZktPgkwd4DUaKgBf","name":"Bash","input":{"command":"python3 -u << 'PYEOF'\n\"\"\"Randomized greedy SAT sweep on instances with ratio > 1.1 and manageable nsofts.\"\"\"\nimport sys, time, random, csv\nsys.path.insert(0, 'library')\nfrom wcnf_parser import parse_wcnf, check_hard_clauses, evaluate_cost\nfrom solutions import update_solution, get_best_costs\nfrom pysat.solvers import Solver\n\nref = {}\nwith open('benchmarks/max-sat-2024/best-costs.csv') as f:\n    reader = csv.reader(f)\n    next(reader)\n    for row in reader:\n        ref[row[0]] = int(row[1])\n\ncosts = get_best_costs()\ntargets = []\nfor inst, rc in ref.items():\n    if rc <= 0 or inst not in costs: continue\n    ratio = costs[inst] / rc\n    if ratio > 1.1:\n        targets.append((ratio, inst, costs[inst], rc))\ntargets.sort(reverse=True)\n\nt0 = time.time()\nimproved = 0\n\nfor ratio, inst, cur_cost, ref_cost in targets:\n    if time.time() - t0 > 250:\n        break\n    \n    path = f'benchmarks/max-sat-2024/mse24-anytime-weighted/{inst}'\n    try:\n        data = parse_wcnf(path)\n    except:\n        continue\n    \n    nvars = data['nvars']\n    hards = data['hard_clauses']\n    softs = data['soft_clauses']\n    nsoft = len(softs)\n    \n    if nsoft > 3000 or nvars > 400000:\n        continue\n    \n    current_best = get_best_costs().get(inst, float('inf'))\n    if current_best / ref_cost < 1.1:\n        continue\n    \n    budget = min(20, int(250 - (time.time()-t0)))\n    if budget < 3: break\n    \n    t1 = time.time()\n    improved_this = False\n    \n    for trial in range(30):\n        if time.time() - t1 > budget:\n            break\n        \n        try:\n            with Solver(name='cd19') as sat:\n                for clause in hards:\n                    sat.add_clause(clause)\n                \n                selectors = []\n                for i, (w, clause) in enumerate(softs):\n                    sel = nvars + 1 + i\n                    selectors.append(sel)\n                    sat.add_clause([-sel] + clause)\n                \n                order = list(range(nsoft))\n                random.shuffle(order)\n                \n                must_satisfy = []\n                for idx in order:\n                    assumptions = must_satisfy + [selectors[idx]]\n                    if sat.solve(assumptions=assumptions):\n                        must_satisfy.append(selectors[idx])\n                \n                if sat.solve(assumptions=must_satisfy):\n                    model = sat.get_model()\n                    sol = [lit for lit in model if abs(lit) <= nvars]\n                    present = set(abs(lit) for lit in sol)\n                    for v in range(1, nvars+1):\n                        if v not in present:\n                            sol.append(v)\n                    cost = evaluate_cost(sol, softs)\n                    \n                    if cost < current_best:\n                        viol = check_hard_clauses(sol, hards)\n                        if not viol:\n                            current_best = cost\n                            update_solution(inst, cost, sol, f'rnd-greedy')\n                            if not improved_this:\n                                improved_this = True\n                                improved += 1\n                            print(f\"  {inst[:50]}: {cost} ({cost/ref_cost:.2f}x) [was {cur_cost}]\", flush=True)\n        except:\n            pass\n    \n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst[:50]} | approach: rnd-greedy | cost: {current_best} | time: {time.time()-t1:.1f} | notes: rnd sweep\\n\")\n\nprint(f\"\\nDone. {improved} improvements in {time.time()-t0:.0f}s\", flush=True)\nPYEOF","description":"Run randomized greedy sweep","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4302,"cache_read_input_tokens":134108,"cache_creation":{"ephemeral_5m_input_tokens":4302,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"a4a2bf75-b99c-4e93-9339-85dbb84ca7bc"}
