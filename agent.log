 solver_name='cd19')\n    print(f\"Core-guided: cost={cost2}\")\n    if sol2 and cost2 < get_best_costs().get(inst, float('inf')):\n        viol = check_hard_clauses(sol2, data['hard_clauses'])\n        if not viol:\n            update_solution(inst, cost2, sol2, 'core-guided-cd19')\n            print(f\"IMPROVED to {cost2}\")\n\n# Log\nwith open('experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: wpm1+core-guided | cost: {cost} | time: {elapsed:.1f} | notes: polysite-bloat deep solve\\n\")\nPYEOF\necho \"polysite-bloat script ready\"","description":"Write polysite-bloat improvement script"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":842,"cache_read_input_tokens":62668,"cache_creation":{"ephemeral_5m_input_tokens":842,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"c41f133d-d1c8-46a9-b245-4203b785db8b"}
