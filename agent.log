aining < 10:\n        break\n    \n    t1 = time.time()\n    best_assign, best_cost = clause_weight_local_search(\n        assignment, softs, hards, occ, timeout=remaining\n    )\n    elapsed = time.time() - t1\n    print(f\"  CWLS: cost={best_cost} ({elapsed:.1f}s)\")\n    \n    if best_cost < current_best:\n        sol_lits = assignment_to_lits(best_assign)\n        viol = check_hard_clauses(sol_lits, hards)\n        if not viol:\n            update_solution(inst, best_cost, sol_lits, 'cwls')\n            print(f\"    IMPROVED: {current_best} -> {best_cost}\")\n    \n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst[:60]} | approach: cwls | cost: {best_cost} | time: {elapsed:.1f} | notes: correlation cwls\\n\")\nPYEOF\necho \"correlation script ready\"","description":"Write correlation-clustering improvement script"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":842,"cache_read_input_tokens":62668,"cache_creation":{"ephemeral_5m_input_tokens":842,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"eb76b05f-23e2-4a93-b637-f3a08acb7e46"}
