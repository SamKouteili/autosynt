nt_best:\n            lits = assignment_to_lits(best_assign)\n            update_solution(inst, best_cost, lits, f\"sa-t{t_start}\")\n            current_best = best_cost\n            print(f\"  {inst[:50]}: SA t={t_start} -> {best_cost} ({best_cost/ref:.2f}x) IMPROVED!\")\n    \n    print(f\"{inst[:50]}: best={current_best} ({current_best/ref:.2f}x) [{time.time()-t0:.1f}s]\")\n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: SA | cost: {current_best} | time: {time.time()-t0:.1f} | notes: simulated annealing\\n\")\nPYEOF","description":"Test simulated annealing on stuck instances","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":792,"cache_read_input_tokens":132064,"cache_creation":{"ephemeral_5m_input_tokens":792,"ephemeral_1h_input_tokens":0},"output_tokens":19,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"38135602-62e8-4094-9f41-0f1fb730f536","uuid":"fe2a0d00-3d27-4a37-a63b-5db3b785ef84"}
