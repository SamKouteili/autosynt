\"--tlsf={tlsf}\", \"--aiger\", \"--algo=lar\"], \"ltlsynt-lar\"),\n        ([\"ltlsynt\", f\"--tlsf={tlsf}\", \"--aiger\", \"--algo=sd\"], \"ltlsynt-sd\"),\n        ([\"ltlsynt\", f\"--tlsf={tlsf}\", \"--aiger\", \"--algo=ds\"], \"ltlsynt-ds\"),\n    ]:\n        try:\n            proc = subprocess.run(cmd, capture_output=True, text=True, timeout=30)\n            output = proc.stdout.strip()\n            if \"UNREALIZABLE\" in output:\n                return inst, \"unrealizable\", method, None, -1\n            elif \"REALIZABLE\" in output and \"UNREALIZABLE\" not in output:\n                parts = output.split(\"\\n\", 1)\n                aiger = parts[1] if len(parts) > 1 else None\n                gates = -1\n                if aiger:\n                    try: gates = int(aiger.strip().split('\\n')[0].split()[5])\n                    except: pass\n                return inst, \"realizable\", method, aiger, gates\n        except subprocess.TimeoutExpired:\n            continue\n    return inst, \"timeout\", None, None, -1\n\nsolved = 0\ndone = 0\nwith ThreadPoolExecutor(max_workers=3) as executor:\n    futures = {executor.submit(solve_one, n): n for n in targets}\n    for future in as_completed(futures):\n        done += 1\n        try:\n            inst, status, method, aiger, gates = future.result(timeout=180)\n            if status == \"unrealizable\":\n                if mark_unrealizable(inst, method):\n                    solved += 1\n                    print(f\"  [U] {inst} ({method})\")\n                    ts = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n                    with open(EXPERIMENTS_LOG, \"a\") as f:\n                        f.write(f\"[{ts}] instance: {inst} | approach: {method} | status: unrealizable | and_gates: N/A | time: 0s | notes: campaign2\\n\")\n            elif status == \"realizable\":\n                if update_solution(inst, 'realizable', aiger, method):\n                    solved += 1\n                    print(f\"  [R] {inst}: {gates}g ({method})\")\n                    ts = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n                    with open(EXPERIMENTS_LOG, \"a\") as f:\n                        f.write(f\"[{ts}] instance: {inst} | approach: {method} | status: realizable | and_gates: {gates} | time: 0s | notes: campaign2\\n\")\n        except Exception:\n            pass\n        if done % 10 == 0:\n            print(f\"  --- {done}/{len(targets)}, +{solved} new ---\")\n\nprint(f\"\\nCampaign 2 done: {done}/{len(targets)}, +{solved} new solutions\")\nPYEOF","description":"Campaign 2: other unsolved families with ltlsynt","timeout":280000,"run_in_background":true},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1737,"cache_read_input_tokens":95535,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1737},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"6882dd44-b12a-40ea-abce-8556d98170ba","uuid":"74583360-56a1-4543-bdbe-37c9ba5f989b"}
