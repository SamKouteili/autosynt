{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013GNUrFJs2rWyAxDQMKEw14","type":"tool_result","content":"     1→\"\"\"Core MaxSAT solver building blocks: occurrence lists, SAT init, tabu search, greedy SAT, WalkSAT.\"\"\"\n     2→\n     3→import random\n     4→import signal\n     5→import time\n     6→\n     7→from pysat.solvers import Solver\n     8→\n     9→\n    10→class SolverTimeout(Exception):\n    11→    pass\n    12→\n    13→\n    14→def sat_solve_with_timeout(solver, assumptions=None, timeout=30):\n    15→    \"\"\"Call solver.solve() with a wall-clock timeout using SIGALRM.\n    16→\n    17→    SAT solver calls are C-level and don't respect Python time checks.\n    18→    SIGALRM interrupts the C code after `timeout` seconds.\n    19→\n    20→    Returns True/False (SAT/UNSAT) or raises SolverTimeout.\n    21→    \"\"\"\n    22→    def _handler(signum, frame):\n    23→        raise SolverTimeout()\n    24→\n    25→    old_handler = signal.signal(signal.SIGALRM, _handler)\n    26→    signal.alarm(timeout)\n    27→    try:\n    28→        if assumptions:\n    29→            result = solver.solve(assumptions=assumptions)\n    30→        else:\n    31→            result = solver.solve()\n    32→        signal.alarm(0)\n    33→        return result\n    34→    except SolverTimeout:\n    35→        signal.alarm(0)\n    36→        raise\n    37→    finally:\n    38→        signal.signal(signal.SIGALRM, old_handler)\n    39→\n    40→\n    41→def build_occurrence_lists(nvars, hard_clauses, soft_clauses):\n    42→    \"\"\"Build variable-to-clause occurrence lists.\n    43→\n    44→    Returns (hard_pos, hard_neg, soft_pos, soft_neg, soft_weights, soft_vars)\n    45→    where *_pos[v] and *_neg[v] are lists of clause indices containing variable v\n    46→    positively/negatively.\n    47→    \"\"\"\n    48→    hard_pos = [[] for _ in range(nvars + 1)]\n    49→    hard_neg = [[] for _ in range(nvars + 1)]\n    50→    soft_pos = [[] for _ in range(nvars + 1)]\n    51→    soft_neg = [[] for _ in range(nvars + 1)]\n    52→    soft_weights = []\n    53→    soft_vars = set()\n    54→\n    55→    for i, (w, clause) in enumerate(soft_clauses):\n    56→        soft_weights.append(w)\n    57→        for lit in clause:\n    58→            v = abs(lit)\n    59→            soft_vars.add(v)\n    60→            if lit > 0:\n    61→                soft_pos[v].append(i)\n    62→            else:\n    63→                soft_neg[v].append(i)\n    64→\n    65→    for i, clause in enumerate(hard_clauses):\n    66→        for lit in clause:\n    67→            v = abs(lit)\n    68→            if lit > 0:\n    69→                hard_pos[v].append(i)\n    70→            else:\n    71→                hard_neg[v].append(i)\n    72→\n    73→    return hard_pos, hard_neg, soft_pos, soft_neg, soft_weights, sorted(soft_vars)\n    74→\n    75→\n    76→def compute_sat_counts(assignment, hard_clauses, soft_clauses):\n    77→    \"\"\"Compute per-clause satisfaction counts for current assignment.\n    78→\n    79→    Returns (hard_sat_count, soft_sat_count).\n    80→    \"\"\"\n    81→    hard_sat_count = [0] * len(hard_clauses)\n    82→    soft_sat_count = [0] * len(soft_clauses)\n    83→\n    84→    for i, clause in enumerate(hard_clauses):\n    85→        for lit in clause:\n    86→            v = abs(lit)\n    87→            if (lit > 0 and assignment[v]) or (lit < 0 and not assignment[v]):\n    88→                hard_sat_count[i] += 1\n    89→\n    90→    for i, (w, clause) in enumerate(soft_clauses):\n    91→        for lit in clause:\n    92→            v = abs(lit)\n    93→            if (lit > 0 and assignment[v]) or (lit < 0 and not assignment[v]):\n    94→                soft_sat_count[i] += 1\n    95→\n    96→    return hard_sat_count, soft_sat_count\n    97→\n    98→\n    99→def flip_variable(v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n   100→                  hard_sat_count, soft_sat_count):\n   101→    \"\"\"Flip variable v in assignment and update all sat counts in place.\"\"\"\n   102→    if assignment[v]:\n   103→        assignment[v] = 0\n   104→        for ci in hard_pos[v]: hard_sat_count[ci] -= 1\n   105→        for ci in hard_neg[v]: hard_sat_count[ci] += 1\n   106→        for ci in soft_pos[v]: soft_sat_count[ci] -= 1\n   107→        for ci in soft_neg[v]: soft_sat_count[ci] += 1\n   108→    else:\n   109→        assignment[v] = 1\n   110→        for ci in hard_pos[v]: hard_sat_count[ci] += 1\n   111→        for ci in hard_neg[v]: hard_sat_count[ci] -= 1\n   112→        for ci in soft_pos[v]: soft_sat_count[ci] += 1\n   113→        for ci in soft_neg[v]: soft_sat_count[ci] -= 1\n   114→\n   115→\n   116→def compute_flip_delta(v, assignment, soft_pos, soft_neg, soft_sat_count, soft_weights):\n   117→    \"\"\"Compute the change in soft cost if variable v is flipped. Negative = improvement.\"\"\"\n   118→    delta = 0\n   119→    if assignment[v]:\n   120→        for ci in soft_pos[v]:\n   121→            if soft_sat_count[ci] == 1: delta += soft_weights[ci]\n   122→        for ci in soft_neg[v]:\n   123→            if soft_sat_count[ci] == 0: delta -= soft_weights[ci]\n   124→    else:\n   125→        for ci in soft_pos[v]:\n   126→            if soft_sat_count[ci] == 0: delta -= soft_weights[ci]\n   127→        for ci in soft_neg[v]:\n   128→            if soft_sat_count[ci] == 1: delta += soft_weights[ci]\n   129→    return delta\n   130→\n   131→\n   132→def flip_preserves_hard(v, assignment, hard_pos, hard_neg, hard_sat_count):\n   133→    \"\"\"Check if flipping v would violate any hard clause.\"\"\"\n   134→    if assignment[v]:\n   135→        for ci in hard_pos[v]:\n   136→            if hard_sat_count[ci] == 1: return False\n   137→    else:\n   138→        for ci in hard_neg[v]:\n   139→            if hard_sat_count[ci] == 1: return False\n   140→    return True\n   141→\n   142→\n   143→def sat_init(hard_clauses, nvars, solver_name='g4'):\n   144→    \"\"\"Find a feasible assignment satisfying all hard clauses using pysat.\n   145→\n   146→    Args:\n   147→        solver_name: 'g4' (glucose4, default) or 'cd19' (CaDiCaL, better for large instances).\n   148→\n   149→    Returns bytearray assignment (1-indexed) or None if UNSAT.\n   150→    \"\"\"\n   151→    with Solver(name=solver_name) as sat:\n   152→        for clause in hard_clauses:\n   153→            sat.add_clause(clause)\n   154→        if not sat.solve():\n   155→            return None\n   156→        model = sat.get_model()\n   157→\n   158→    assignment = bytearray(nvars + 1)\n   159→    for lit in model:\n   160→        v = abs(lit)\n   161→        if v <= nvars:\n   162→            assignment[v] = 1 if lit > 0 else 0\n   163→    return assignment\n   164→\n   165→\n   166→def greedy_sat(nvars, hard_clauses, soft_clauses, timeout=240, solver_name='g4'):\n   167→    \"\"\"Greedy SAT with selector variables for instances with few soft clauses.\n   168→\n   169→    Sorts soft clauses by weight (heaviest first) and greedily tries to satisfy each\n   170→    using SAT solver with assumptions. Best for nsofts < ~500.\n   171→\n   172→    Args:\n   173→        solver_name: pysat solver name. 'g4' (glucose4) is default, 'cd19' (CaDiCaL)\n   174→                     is better for instances where glucose4 gets stuck.\n   175→\n   176→    Returns (solution_lits, cost) or (None, None).\n   177→    \"\"\"\n   178→    nsoft = len(soft_clauses)\n   179→    t0 = time.time()\n   180→\n   181→    with Solver(name=solver_name) as sat:\n   182→        for clause in hard_clauses:\n   183→            sat.add_clause(clause)\n   184→\n   185→        selectors = []\n   186→        for i, (w, clause) in enumerate(soft_clauses):\n   187→            sel = nvars + 1 + i\n   188→            selectors.append(sel)\n   189→            sat.add_clause([-sel] + clause)\n   190→\n   191→        indexed_softs = sorted(range(nsoft), key=lambda i: soft_clauses[i][0], reverse=True)\n   192→\n   193→        must_satisfy = []\n   194→        best_cost = sum(w for w, _ in soft_clauses)\n   195→        best_model = None\n   196→\n   197→        if sat.solve():\n   198→            model = sat.get_model()\n   199→            true_lits = set(model)\n   200→            cost = sum(w for w, cl in soft_clauses if not any(lit in true_lits for lit in cl))\n   201→            if cost < best_cost:\n   202→                best_cost = cost\n   203→                best_model = model\n   204→\n   205→        for idx in indexed_softs:\n   206→            if time.time() - t0 > timeout:\n   207→                break\n   208→            assumptions = must_satisfy + [selectors[idx]]\n   209→            if sat.solve(assumptions=assumptions):\n   210→                must_satisfy.append(selectors[idx])\n   211→                model = sat.get_model()\n   212→                true_lits = set(model)\n   213→                cost = sum(w for w, cl in soft_clauses if not any(lit in true_lits for lit in cl))\n   214→                if cost < best_cost:\n   215→                    best_cost = cost\n   216→                    best_model = model\n   217→\n   218→    if best_model is None:\n   219→        return None, None\n   220→\n   221→    solution = [lit for lit in best_model if abs(lit) <= nvars]\n   222→    present = set(abs(lit) for lit in solution)\n   223→    for v in range(1, nvars + 1):\n   224→        if v not in present:\n   225→            solution.append(v)\n   226→    return solution, best_cost\n   227→\n   228→\n   229→def _update_neighbor_scores(v, assignment, soft_clauses, soft_pos, soft_neg,\n   230→                            soft_sat_count, soft_weights, score):\n   231→    \"\"\"Incrementally update score array for neighbors after flipping v.\n   232→\n   233→    Call AFTER flip_variable. Then recompute score[v] separately since neighbor\n   234→    updates may touch v's score through shared clauses.\n   235→    \"\"\"\n   236→    if assignment[v]:\n   237→        # v was just set to 1: soft_pos sat_count increased, soft_neg decreased\n   238→        for ci in soft_pos[v]:\n   239→            w = soft_weights[ci]\n   240→            if soft_sat_count[ci] == 1:\n   241→                # 0→1: clause became satisfied, vars that could make it no longer gain\n   242→                for lit in soft_clauses[ci][1]:\n   243→                    vv = abs(lit)\n   244→                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n   245→                        score[vv] += w\n   246→            elif soft_sat_count[ci] == 2:\n   247→                # 1→2: other satisfier no longer breaks\n   248→                for lit in soft_clauses[ci][1]:\n   249→                    vv = abs(lit)\n   250→                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n   251→                        score[vv] -= w\n   252→                        break\n   253→        for ci in soft_neg[v]:\n   254→            w = soft_weights[ci]\n   255→            if soft_sat_count[ci] == 0:\n   256→                # 1→0: clause became unsatisfied, vars that could make it now gain\n   257→                for lit in soft_clauses[ci][1]:\n   258→                    vv = abs(lit)\n   259→                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n   260→                        score[vv] -= w\n   261→            elif soft_sat_count[ci] == 1:\n   262→                # 2→1: remaining satisfier now breaks\n   263→                for lit in soft_clauses[ci][1]:\n   264→                    vv = abs(lit)\n   265→                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n   266→                        score[vv] += w\n   267→                        break\n   268→    else:\n   269→        # v was just set to 0: soft_neg sat_count increased, soft_pos decreased\n   270→        for ci in soft_neg[v]:\n   271→            w = soft_weights[ci]\n   272→            if soft_sat_count[ci] == 1:\n   273→                for lit in soft_clauses[ci][1]:\n   274→                    vv = abs(lit)\n   275→                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n   276→                        score[vv] += w\n   277→            elif soft_sat_count[ci] == 2:\n   278→                for lit in soft_clauses[ci][1]:\n   279→                    vv = abs(lit)\n   280→                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n   281→                        score[vv] -= w\n   282→                        break\n   283→        for ci in soft_pos[v]:\n   284→            w = soft_weights[ci]\n   285→            if soft_sat_count[ci] == 0:\n   286→                for lit in soft_clauses[ci][1]:\n   287→                    vv = abs(lit)\n   288→                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n   289→                        score[vv] -= w\n   290→            elif soft_sat_count[ci] == 1:\n   291→                for lit in soft_clauses[ci][1]:\n   292→                    vv = abs(lit)\n   293→                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n   294→                        score[vv] += w\n   295→                        break\n   296→\n   297→    # Recompute score[v] from scratch — neighbor updates above may have touched it\n   298→    # through shared clauses\n   299→    score[v] = compute_flip_delta(v, assignment, soft_pos, soft_neg, soft_sat_count, soft_weights)\n   300→\n   301→\n   302→def tabu_search(assignment, soft_clauses, hard_clauses, occ_lists, timeout=240,\n   303→                candidates=None, restarts=1, perturb_prob=0.2):\n   304→    \"\"\"Tabu search on soft-clause cost, preserving hard clause feasibility.\n   305→\n   306→    Uses incremental score maintenance: O(clause_length) per step for score updates\n   307→    instead of O(candidates * clause_length) for full recomputation.\n   308→\n   309→    Args:\n   310→        assignment: bytearray, initial feasible assignment (1-indexed)\n   311→        soft_clauses: list of (weight, clause)\n   312→        hard_clauses: list of clauses\n   313→        occ_lists: tuple from build_occurrence_lists\n   314→        timeout: seconds\n   315→        candidates: list of variables to consider flipping (default: soft_vars)\n   316→        restarts: number of trials with random perturbation (default: 1)\n   317→        perturb_prob: probability of flipping each candidate on restart (default: 0.2)\n   318→\n   319→    Returns (best_assignment, best_cost).\n   320→    \"\"\"\n   321→    hard_pos, hard_neg, soft_pos, soft_neg, soft_weights, soft_vars = occ_lists\n   322→    if candidates is None:\n   323→        candidates = soft_vars\n   324→    nvars = len(assignment) - 1\n   325→    nsoft = len(soft_clauses)\n   326→\n   327→    t0 = time.time()\n   328→    overall_best_cost = float('inf')\n   329→    overall_best_assign = None\n   330→    init_assignment = bytearray(assignment)\n   331→\n   332→    for trial in range(restarts):\n   333→        if time.time() - t0 > timeout:\n   334→            break\n   335→        trial_deadline = min(t0 + timeout, time.time() + timeout / max(1, restarts - trial))\n   336→\n   337→        # Reset to initial assignment with perturbation on restarts\n   338→        assignment = bytearray(init_assignment)\n   339→        if trial > 0:\n   340→            for v in candidates:\n   341→                if random.random() < perturb_prob:\n   342→                    assignment[v] = 1 - assignment[v]\n   343→            # Fix hard violations via walksat if we have hard clauses\n   344→            if hard_clauses:\n   345→                hard_sat_count_tmp = [0] * len(hard_clauses)\n   346→                for i, clause in enumerate(hard_clauses):\n   347→                    for lit in clause:\n   348→                        v = abs(lit)\n   349→                        if (lit > 0 and assignment[v]) or (lit < 0 and not assignment[v]):\n   350→                            hard_sat_count_tmp[i] += 1\n   351→                remaining = walksat_hard(assignment, hard_clauses, hard_pos, hard_neg,\n   352→                                         hard_sat_count_tmp)\n   353→                if remaining > 0:\n   354→                    continue\n   355→\n   356→        hard_sat_count, soft_sat_count = compute_sat_counts(assignment, hard_clauses, soft_clauses)\n   357→        current_cost = sum(soft_weights[i] for i in range(nsoft) if soft_sat_count[i] == 0)\n   358→        best_cost = current_cost\n   359→        best_assign = bytearray(assignment)\n   360→\n   361→        # Initialize scores\n   362→        score = [0] * (nvars + 1)\n   363→        for v in candidates:\n   364→            score[v] = compute_flip_delta(v, assignment, soft_pos, soft_neg, soft_sat_count, soft_weights)\n   365→\n   366→        tabu = {}\n   367→        tabu_tenure = max(7, len(candidates) // 5)\n   368→        step = 0\n   369→\n   370→        while time.time() < trial_deadline:\n   371→            step += 1\n   372→            best_v = -1\n   373→            best_delta = float('inf')\n   374→\n   375→            for v in candidates:\n   376→                if score[v] < best_delta:\n   377→                    if v not in tabu or tabu[v] <= step or current_cost + score[v] < best_cost:\n   378→                        if flip_preserves_hard(v, assignment, hard_pos, hard_neg, hard_sat_count):\n   379→                            best_delta = score[v]\n   380→                            best_v = v\n   381→\n   382→            if best_v == -1:\n   383→                break\n   384→\n   385→            flip_variable(best_v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n   386→                          hard_sat_count, soft_sat_count)\n   387→            current_cost += best_delta\n   388→            _update_neighbor_scores(best_v, assignment, soft_clauses, soft_pos, soft_neg,\n   389→                                    soft_sat_count, soft_weights, score)\n   390→            tabu[best_v] = step + tabu_tenure + random.randint(0, 3)\n   391→\n   392→            if current_cost < best_cost:\n   393→                best_cost = current_cost\n   394→                best_assign = bytearray(assignment)\n   395→\n   396→        if best_cost < overall_best_cost:\n   397→            overall_best_cost = best_cost\n   398→            overall_best_assign = bytearray(best_assign)\n   399→\n   400→    return overall_best_assign, overall_best_cost\n   401→\n   402→\n   403→def walksat_hard(assignment, hard_clauses, hard_pos, hard_neg, hard_sat_count,\n   404→                 max_iters=500000, noise_prob=0.4):\n   405→    \"\"\"WalkSAT to fix hard clause violations in place.\n   406→\n   407→    Modifies assignment and hard_sat_count. Returns number of remaining violations.\n   408→    \"\"\"\n   409→    nhard = len(hard_clauses)\n   410→    for _ in range(max_iters):\n   411→        unsat = [i for i in range(nhard) if hard_sat_count[i] == 0]\n   412→        if not unsat:\n   413→            return 0\n   414→        ci = random.choice(unsat)\n   415→        lit = random.choice(hard_clauses[ci])\n   416→        v = abs(lit)\n   417→        if assignment[v]:\n   418→            assignment[v] = 0\n   419→            for j in hard_pos[v]: hard_sat_count[j] -= 1\n   420→            for j in hard_neg[v]: hard_sat_count[j] += 1\n   421→        else:\n   422→            assignment[v] = 1\n   423→            for j in hard_pos[v]: hard_sat_count[j] += 1\n   424→            for j in hard_neg[v]: hard_sat_count[j] -= 1\n   425→    return sum(1 for i in range(nhard) if hard_sat_count[i] == 0)\n   426→\n   427→\n   428→def walksat_soft(assignment, soft_clauses, hard_clauses, occ_lists, timeout=120):\n   429→    \"\"\"WalkSAT-based soft clause optimizer for instances with many hard + soft clauses.\n   430→\n   431→    Instead of scanning all candidates (slow with large occurrence lists), picks random\n   432→    unsatisfied soft clauses and tries to flip variables to satisfy them.\n   433→    O(clause_length) per step instead of O(candidates * occurrence_length).\n   434→\n   435→    Best for: instances with many soft clauses AND many hard clauses (e.g. ParametricRBAC domino).\n   436→    \"\"\"\n   437→    hard_pos, hard_neg, soft_pos, soft_neg, soft_weights, soft_vars = occ_lists\n   438→    hard_sat_count, soft_sat_count = compute_sat_counts(assignment, hard_clauses, soft_clauses)\n   439→    nsoft = len(soft_clauses)\n   440→\n   441→    current_cost = sum(soft_weights[i] for i in range(nsoft) if soft_sat_count[i] == 0)\n   442→    best_cost = current_cost\n   443→    best_assign = bytearray(assignment)\n   444→\n   445→    deadline = time.time() + timeout\n   446→    while time.time() < deadline:\n   447→        unsat_softs = [i for i in range(nsoft) if soft_sat_count[i] == 0]\n   448→        if not unsat_softs:\n   449→            break\n   450→        ci = random.choice(unsat_softs)\n   451→        w, clause = soft_clauses[ci]\n   452→        random.shuffle(clause)\n   453→        for lit in clause:\n   454→            v = abs(lit)\n   455→            would_satisfy = (lit > 0 and not assignment[v]) or (lit < 0 and assignment[v])\n   456→            if not would_satisfy:\n   457→                continue\n   458→            if flip_preserves_hard(v, assignment, hard_pos, hard_neg, hard_sat_count):\n   459→                flip_variable(v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n   460→                            hard_sat_count, soft_sat_count)\n   461→                current_cost = sum(soft_weights[j] for j in range(nsoft) if soft_sat_count[j] == 0)\n   462→                if current_cost < best_cost:\n   463→                    best_cost = current_cost\n   464→                    best_assign = bytearray(assignment)\n   465→                break\n   466→\n   467→    return best_assign, best_cost\n   468→\n   469→\n   470→def multi_init(nvars, hard_clauses, soft_clauses, timeout=60, max_trials=500,\n   471→               solvers=None):\n   472→    \"\"\"Multi-init: run multiple SAT solvers with random assumptions to find diverse solutions.\n   473→\n   474→    Key discovery: different solvers and random variable assumptions produce wildly different\n   475→    feasible assignments with very different soft costs. Extremely effective for breaking out\n   476→    of single-solver local optima.\n   477→\n   478→    Does NOT help for judgment-aggregation (all SAT baselines are terrible for those).\n   479→\n   480→    Args:\n   481→        nvars: number of variables\n   482→        hard_clauses: list of clauses\n   483→        soft_clauses: list of (weight, clause)\n   484→        timeout: seconds\n   485→        max_trials: max number of solver invocations\n   486→        solvers: list of pysat solver names (default: ['cd19', 'g4', 'cd15', 'mc'] for small,\n   487→                 ['cd19', 'cd15'] for large)\n   488→\n   489→    Returns (best_solution_lits, best_cost) or (None, None).\n   490→    \"\"\"\n   491→    if solvers is None:\n   492→        solvers = ['cd19', 'g4', 'cd15', 'mc'] if nvars < 300000 else ['cd19', 'cd15']\n   493→\n   494→    best_cost = float('inf')\n   495→    best_sol = None\n   496→    t0 = time.time()\n   497→\n   498→    for trial in range(max_trials):\n   499→        if time.time() - t0 > timeout:\n   500→            break\n   501→        sn = random.choice(solvers)\n   502→        try:\n   503→            with Solver(name=sn) as sat:\n   504→                for clause in hard_clauses:\n   505→                    sat.add_clause(clause)\n   506→                n_assumptions = max(1, min(int(nvars * random.uniform(0.005, 0.3)), 300))\n   507→                assumptions = [random.choice([v, -v]) for v in random.sample(range(1, nvars + 1), n_assumptions)]\n   508→                if sat.solve(assumptions=assumptions):\n   509→                    model = sat.get_model()\n   510→                elif sat.solve():\n   511→                    model = sat.get_model()\n   512→                else:\n   513→                    continue\n   514→                solution = [lit for lit in model if abs(lit) <= nvars]\n   515→                present = set(abs(lit) for lit in solution)\n   516→                for v in range(1, nvars + 1):\n   517→                    if v not in present:\n   518→                        solution.append(v)\n   519→                from library.wcnf_parser import evaluate_cost\n   520→                cost = evaluate_cost(solution, soft_clauses)\n   521→                if cost < best_cost:\n   522→                    best_cost = cost\n   523→                    best_sol = solution\n   524→        except Exception:\n   525→            pass\n   526→\n   527→    return best_sol, best_cost\n   528→\n   529→\n   530→def assignment_to_lits(assignment):\n   531→    \"\"\"Convert bytearray assignment to signed literal list.\"\"\"\n   532→    return [v if assignment[v] else -v for v in range(1, len(assignment))]\n   533→"}]},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"19b8bc47-9aca-4602-b199-82ca984abd3e","tool_use_result":{"type":"text","file":{"filePath":"/tmp/agent-sat-3/library/solvers.py","content":"\"\"\"Core MaxSAT solver building blocks: occurrence lists, SAT init, tabu search, greedy SAT, WalkSAT.\"\"\"\n\nimport random\nimport signal\nimport time\n\nfrom pysat.solvers import Solver\n\n\nclass SolverTimeout(Exception):\n    pass\n\n\ndef sat_solve_with_timeout(solver, assumptions=None, timeout=30):\n    \"\"\"Call solver.solve() with a wall-clock timeout using SIGALRM.\n\n    SAT solver calls are C-level and don't respect Python time checks.\n    SIGALRM interrupts the C code after `timeout` seconds.\n\n    Returns True/False (SAT/UNSAT) or raises SolverTimeout.\n    \"\"\"\n    def _handler(signum, frame):\n        raise SolverTimeout()\n\n    old_handler = signal.signal(signal.SIGALRM, _handler)\n    signal.alarm(timeout)\n    try:\n        if assumptions:\n            result = solver.solve(assumptions=assumptions)\n        else:\n            result = solver.solve()\n        signal.alarm(0)\n        return result\n    except SolverTimeout:\n        signal.alarm(0)\n        raise\n    finally:\n        signal.signal(signal.SIGALRM, old_handler)\n\n\ndef build_occurrence_lists(nvars, hard_clauses, soft_clauses):\n    \"\"\"Build variable-to-clause occurrence lists.\n\n    Returns (hard_pos, hard_neg, soft_pos, soft_neg, soft_weights, soft_vars)\n    where *_pos[v] and *_neg[v] are lists of clause indices containing variable v\n    positively/negatively.\n    \"\"\"\n    hard_pos = [[] for _ in range(nvars + 1)]\n    hard_neg = [[] for _ in range(nvars + 1)]\n    soft_pos = [[] for _ in range(nvars + 1)]\n    soft_neg = [[] for _ in range(nvars + 1)]\n    soft_weights = []\n    soft_vars = set()\n\n    for i, (w, clause) in enumerate(soft_clauses):\n        soft_weights.append(w)\n        for lit in clause:\n            v = abs(lit)\n            soft_vars.add(v)\n            if lit > 0:\n                soft_pos[v].append(i)\n            else:\n                soft_neg[v].append(i)\n\n    for i, clause in enumerate(hard_clauses):\n        for lit in clause:\n            v = abs(lit)\n            if lit > 0:\n                hard_pos[v].append(i)\n            else:\n                hard_neg[v].append(i)\n\n    return hard_pos, hard_neg, soft_pos, soft_neg, soft_weights, sorted(soft_vars)\n\n\ndef compute_sat_counts(assignment, hard_clauses, soft_clauses):\n    \"\"\"Compute per-clause satisfaction counts for current assignment.\n\n    Returns (hard_sat_count, soft_sat_count).\n    \"\"\"\n    hard_sat_count = [0] * len(hard_clauses)\n    soft_sat_count = [0] * len(soft_clauses)\n\n    for i, clause in enumerate(hard_clauses):\n        for lit in clause:\n            v = abs(lit)\n            if (lit > 0 and assignment[v]) or (lit < 0 and not assignment[v]):\n                hard_sat_count[i] += 1\n\n    for i, (w, clause) in enumerate(soft_clauses):\n        for lit in clause:\n            v = abs(lit)\n            if (lit > 0 and assignment[v]) or (lit < 0 and not assignment[v]):\n                soft_sat_count[i] += 1\n\n    return hard_sat_count, soft_sat_count\n\n\ndef flip_variable(v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n                  hard_sat_count, soft_sat_count):\n    \"\"\"Flip variable v in assignment and update all sat counts in place.\"\"\"\n    if assignment[v]:\n        assignment[v] = 0\n        for ci in hard_pos[v]: hard_sat_count[ci] -= 1\n        for ci in hard_neg[v]: hard_sat_count[ci] += 1\n        for ci in soft_pos[v]: soft_sat_count[ci] -= 1\n        for ci in soft_neg[v]: soft_sat_count[ci] += 1\n    else:\n        assignment[v] = 1\n        for ci in hard_pos[v]: hard_sat_count[ci] += 1\n        for ci in hard_neg[v]: hard_sat_count[ci] -= 1\n        for ci in soft_pos[v]: soft_sat_count[ci] += 1\n        for ci in soft_neg[v]: soft_sat_count[ci] -= 1\n\n\ndef compute_flip_delta(v, assignment, soft_pos, soft_neg, soft_sat_count, soft_weights):\n    \"\"\"Compute the change in soft cost if variable v is flipped. Negative = improvement.\"\"\"\n    delta = 0\n    if assignment[v]:\n        for ci in soft_pos[v]:\n            if soft_sat_count[ci] == 1: delta += soft_weights[ci]\n        for ci in soft_neg[v]:\n            if soft_sat_count[ci] == 0: delta -= soft_weights[ci]\n    else:\n        for ci in soft_pos[v]:\n            if soft_sat_count[ci] == 0: delta -= soft_weights[ci]\n        for ci in soft_neg[v]:\n            if soft_sat_count[ci] == 1: delta += soft_weights[ci]\n    return delta\n\n\ndef flip_preserves_hard(v, assignment, hard_pos, hard_neg, hard_sat_count):\n    \"\"\"Check if flipping v would violate any hard clause.\"\"\"\n    if assignment[v]:\n        for ci in hard_pos[v]:\n            if hard_sat_count[ci] == 1: return False\n    else:\n        for ci in hard_neg[v]:\n            if hard_sat_count[ci] == 1: return False\n    return True\n\n\ndef sat_init(hard_clauses, nvars, solver_name='g4'):\n    \"\"\"Find a feasible assignment satisfying all hard clauses using pysat.\n\n    Args:\n        solver_name: 'g4' (glucose4, default) or 'cd19' (CaDiCaL, better for large instances).\n\n    Returns bytearray assignment (1-indexed) or None if UNSAT.\n    \"\"\"\n    with Solver(name=solver_name) as sat:\n        for clause in hard_clauses:\n            sat.add_clause(clause)\n        if not sat.solve():\n            return None\n        model = sat.get_model()\n\n    assignment = bytearray(nvars + 1)\n    for lit in model:\n        v = abs(lit)\n        if v <= nvars:\n            assignment[v] = 1 if lit > 0 else 0\n    return assignment\n\n\ndef greedy_sat(nvars, hard_clauses, soft_clauses, timeout=240, solver_name='g4'):\n    \"\"\"Greedy SAT with selector variables for instances with few soft clauses.\n\n    Sorts soft clauses by weight (heaviest first) and greedily tries to satisfy each\n    using SAT solver with assumptions. Best for nsofts < ~500.\n\n    Args:\n        solver_name: pysat solver name. 'g4' (glucose4) is default, 'cd19' (CaDiCaL)\n                     is better for instances where glucose4 gets stuck.\n\n    Returns (solution_lits, cost) or (None, None).\n    \"\"\"\n    nsoft = len(soft_clauses)\n    t0 = time.time()\n\n    with Solver(name=solver_name) as sat:\n        for clause in hard_clauses:\n            sat.add_clause(clause)\n\n        selectors = []\n        for i, (w, clause) in enumerate(soft_clauses):\n            sel = nvars + 1 + i\n            selectors.append(sel)\n            sat.add_clause([-sel] + clause)\n\n        indexed_softs = sorted(range(nsoft), key=lambda i: soft_clauses[i][0], reverse=True)\n\n        must_satisfy = []\n        best_cost = sum(w for w, _ in soft_clauses)\n        best_model = None\n\n        if sat.solve():\n            model = sat.get_model()\n            true_lits = set(model)\n            cost = sum(w for w, cl in soft_clauses if not any(lit in true_lits for lit in cl))\n            if cost < best_cost:\n                best_cost = cost\n                best_model = model\n\n        for idx in indexed_softs:\n            if time.time() - t0 > timeout:\n                break\n            assumptions = must_satisfy + [selectors[idx]]\n            if sat.solve(assumptions=assumptions):\n                must_satisfy.append(selectors[idx])\n                model = sat.get_model()\n                true_lits = set(model)\n                cost = sum(w for w, cl in soft_clauses if not any(lit in true_lits for lit in cl))\n                if cost < best_cost:\n                    best_cost = cost\n                    best_model = model\n\n    if best_model is None:\n        return None, None\n\n    solution = [lit for lit in best_model if abs(lit) <= nvars]\n    present = set(abs(lit) for lit in solution)\n    for v in range(1, nvars + 1):\n        if v not in present:\n            solution.append(v)\n    return solution, best_cost\n\n\ndef _update_neighbor_scores(v, assignment, soft_clauses, soft_pos, soft_neg,\n                            soft_sat_count, soft_weights, score):\n    \"\"\"Incrementally update score array for neighbors after flipping v.\n\n    Call AFTER flip_variable. Then recompute score[v] separately since neighbor\n    updates may touch v's score through shared clauses.\n    \"\"\"\n    if assignment[v]:\n        # v was just set to 1: soft_pos sat_count increased, soft_neg decreased\n        for ci in soft_pos[v]:\n            w = soft_weights[ci]\n            if soft_sat_count[ci] == 1:\n                # 0→1: clause became satisfied, vars that could make it no longer gain\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n                        score[vv] += w\n            elif soft_sat_count[ci] == 2:\n                # 1→2: other satisfier no longer breaks\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n                        score[vv] -= w\n                        break\n        for ci in soft_neg[v]:\n            w = soft_weights[ci]\n            if soft_sat_count[ci] == 0:\n                # 1→0: clause became unsatisfied, vars that could make it now gain\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n                        score[vv] -= w\n            elif soft_sat_count[ci] == 1:\n                # 2→1: remaining satisfier now breaks\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n                        score[vv] += w\n                        break\n    else:\n        # v was just set to 0: soft_neg sat_count increased, soft_pos decreased\n        for ci in soft_neg[v]:\n            w = soft_weights[ci]\n            if soft_sat_count[ci] == 1:\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n                        score[vv] += w\n            elif soft_sat_count[ci] == 2:\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n                        score[vv] -= w\n                        break\n        for ci in soft_pos[v]:\n            w = soft_weights[ci]\n            if soft_sat_count[ci] == 0:\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n                        score[vv] -= w\n            elif soft_sat_count[ci] == 1:\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n                        score[vv] += w\n                        break\n\n    # Recompute score[v] from scratch — neighbor updates above may have touched it\n    # through shared clauses\n    score[v] = compute_flip_delta(v, assignment, soft_pos, soft_neg, soft_sat_count, soft_weights)\n\n\ndef tabu_search(assignment, soft_clauses, hard_clauses, occ_lists, timeout=240,\n                candidates=None, restarts=1, perturb_prob=0.2):\n    \"\"\"Tabu search on soft-clause cost, preserving hard clause feasibility.\n\n    Uses incremental score maintenance: O(clause_length) per step for score updates\n    instead of O(candidates * clause_length) for full recomputation.\n\n    Args:\n        assignment: bytearray, initial feasible assignment (1-indexed)\n        soft_clauses: list of (weight, clause)\n        hard_clauses: list of clauses\n        occ_lists: tuple from build_occurrence_lists\n        timeout: seconds\n        candidates: list of variables to consider flipping (default: soft_vars)\n        restarts: number of trials with random perturbation (default: 1)\n        perturb_prob: probability of flipping each candidate on restart (default: 0.2)\n\n    Returns (best_assignment, best_cost).\n    \"\"\"\n    hard_pos, hard_neg, soft_pos, soft_neg, soft_weights, soft_vars = occ_lists\n    if candidates is None:\n        candidates = soft_vars\n    nvars = len(assignment) - 1\n    nsoft = len(soft_clauses)\n\n    t0 = time.time()\n    overall_best_cost = float('inf')\n    overall_best_assign = None\n    init_assignment = bytearray(assignment)\n\n    for trial in range(restarts):\n        if time.time() - t0 > timeout:\n            break\n        trial_deadline = min(t0 + timeout, time.time() + timeout / max(1, restarts - trial))\n\n        # Reset to initial assignment with perturbation on restarts\n        assignment = bytearray(init_assignment)\n        if trial > 0:\n            for v in candidates:\n                if random.random() < perturb_prob:\n                    assignment[v] = 1 - assignment[v]\n            # Fix hard violations via walksat if we have hard clauses\n            if hard_clauses:\n                hard_sat_count_tmp = [0] * len(hard_clauses)\n                for i, clause in enumerate(hard_clauses):\n                    for lit in clause:\n                        v = abs(lit)\n                        if (lit > 0 and assignment[v]) or (lit < 0 and not assignment[v]):\n                            hard_sat_count_tmp[i] += 1\n                remaining = walksat_hard(assignment, hard_clauses, hard_pos, hard_neg,\n                                         hard_sat_count_tmp)\n                if remaining > 0:\n                    continue\n\n        hard_sat_count, soft_sat_count = compute_sat_counts(assignment, hard_clauses, soft_clauses)\n        current_cost = sum(soft_weights[i] for i in range(nsoft) if soft_sat_count[i] == 0)\n        best_cost = current_cost\n        best_assign = bytearray(assignment)\n\n        # Initialize scores\n        score = [0] * (nvars + 1)\n        for v in candidates:\n            score[v] = compute_flip_delta(v, assignment, soft_pos, soft_neg, soft_sat_count, soft_weights)\n\n        tabu = {}\n        tabu_tenure = max(7, len(candidates) // 5)\n        step = 0\n\n        while time.time() < trial_deadline:\n            step += 1\n            best_v = -1\n            best_delta = float('inf')\n\n            for v in candidates:\n                if score[v] < best_delta:\n                    if v not in tabu or tabu[v] <= step or current_cost + score[v] < best_cost:\n                        if flip_preserves_hard(v, assignment, hard_pos, hard_neg, hard_sat_count):\n                            best_delta = score[v]\n                            best_v = v\n\n            if best_v == -1:\n                break\n\n            flip_variable(best_v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n                          hard_sat_count, soft_sat_count)\n            current_cost += best_delta\n            _update_neighbor_scores(best_v, assignment, soft_clauses, soft_pos, soft_neg,\n                                    soft_sat_count, soft_weights, score)\n            tabu[best_v] = step + tabu_tenure + random.randint(0, 3)\n\n            if current_cost < best_cost:\n                best_cost = current_cost\n                best_assign = bytearray(assignment)\n\n        if best_cost < overall_best_cost:\n            overall_best_cost = best_cost\n            overall_best_assign = bytearray(best_assign)\n\n    return overall_best_assign, overall_best_cost\n\n\ndef walksat_hard(assignment, hard_clauses, hard_pos, hard_neg, hard_sat_count,\n                 max_iters=500000, noise_prob=0.4):\n    \"\"\"WalkSAT to fix hard clause violations in place.\n\n    Modifies assignment and hard_sat_count. Returns number of remaining violations.\n    \"\"\"\n    nhard = len(hard_clauses)\n    for _ in range(max_iters):\n        unsat = [i for i in range(nhard) if hard_sat_count[i] == 0]\n        if not unsat:\n            return 0\n        ci = random.choice(unsat)\n        lit = random.choice(hard_clauses[ci])\n        v = abs(lit)\n        if assignment[v]:\n            assignment[v] = 0\n            for j in hard_pos[v]: hard_sat_count[j] -= 1\n            for j in hard_neg[v]: hard_sat_count[j] += 1\n        else:\n            assignment[v] = 1\n            for j in hard_pos[v]: hard_sat_count[j] += 1\n            for j in hard_neg[v]: hard_sat_count[j] -= 1\n    return sum(1 for i in range(nhard) if hard_sat_count[i] == 0)\n\n\ndef walksat_soft(assignment, soft_clauses, hard_clauses, occ_lists, timeout=120):\n    \"\"\"WalkSAT-based soft clause optimizer for instances with many hard + soft clauses.\n\n    Instead of scanning all candidates (slow with large occurrence lists), picks random\n    unsatisfied soft clauses and tries to flip variables to satisfy them.\n    O(clause_length) per step instead of O(candidates * occurrence_length).\n\n    Best for: instances with many soft clauses AND many hard clauses (e.g. ParametricRBAC domino).\n    \"\"\"\n    hard_pos, hard_neg, soft_pos, soft_neg, soft_weights, soft_vars = occ_lists\n    hard_sat_count, soft_sat_count = compute_sat_counts(assignment, hard_clauses, soft_clauses)\n    nsoft = len(soft_clauses)\n\n    current_cost = sum(soft_weights[i] for i in range(nsoft) if soft_sat_count[i] == 0)\n    best_cost = current_cost\n    best_assign = bytearray(assignment)\n\n    deadline = time.time() + timeout\n    while time.time() < deadline:\n        unsat_softs = [i for i in range(nsoft) if soft_sat_count[i] == 0]\n        if not unsat_softs:\n            break\n        ci = random.choice(unsat_softs)\n        w, clause = soft_clauses[ci]\n        random.shuffle(clause)\n        for lit in clause:\n            v = abs(lit)\n            would_satisfy = (lit > 0 and not assignment[v]) or (lit < 0 and assignment[v])\n            if not would_satisfy:\n                continue\n            if flip_preserves_hard(v, assignment, hard_pos, hard_neg, hard_sat_count):\n                flip_variable(v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n                            hard_sat_count, soft_sat_count)\n                current_cost = sum(soft_weights[j] for j in range(nsoft) if soft_sat_count[j] == 0)\n                if current_cost < best_cost:\n                    best_cost = current_cost\n                    best_assign = bytearray(assignment)\n                break\n\n    return best_assign, best_cost\n\n\ndef multi_init(nvars, hard_clauses, soft_clauses, timeout=60, max_trials=500,\n               solvers=None):\n    \"\"\"Multi-init: run multiple SAT solvers with random assumptions to find diverse solutions.\n\n    Key discovery: different solvers and random variable assumptions produce wildly different\n    feasible assignments with very different soft costs. Extremely effective for breaking out\n    of single-solver local optima.\n\n    Does NOT help for judgment-aggregation (all SAT baselines are terrible for those).\n\n    Args:\n        nvars: number of variables\n        hard_clauses: list of clauses\n        soft_clauses: list of (weight, clause)\n        timeout: seconds\n        max_trials: max number of solver invocations\n        solvers: list of pysat solver names (default: ['cd19', 'g4', 'cd15', 'mc'] for small,\n                 ['cd19', 'cd15'] for large)\n\n    Returns (best_solution_lits, best_cost) or (None, None).\n    \"\"\"\n    if solvers is None:\n        solvers = ['cd19', 'g4', 'cd15', 'mc'] if nvars < 300000 else ['cd19', 'cd15']\n\n    best_cost = float('inf')\n    best_sol = None\n    t0 = time.time()\n\n    for trial in range(max_trials):\n        if time.time() - t0 > timeout:\n            break\n        sn = random.choice(solvers)\n        try:\n            with Solver(name=sn) as sat:\n                for clause in hard_clauses:\n                    sat.add_clause(clause)\n                n_assumptions = max(1, min(int(nvars * random.uniform(0.005, 0.3)), 300))\n                assumptions = [random.choice([v, -v]) for v in random.sample(range(1, nvars + 1), n_assumptions)]\n                if sat.solve(assumptions=assumptions):\n                    model = sat.get_model()\n                elif sat.solve():\n                    model = sat.get_model()\n                else:\n                    continue\n                solution = [lit for lit in model if abs(lit) <= nvars]\n                present = set(abs(lit) for lit in solution)\n                for v in range(1, nvars + 1):\n                    if v not in present:\n                        solution.append(v)\n                from library.wcnf_parser import evaluate_cost\n                cost = evaluate_cost(solution, soft_clauses)\n                if cost < best_cost:\n                    best_cost = cost\n                    best_sol = solution\n        except Exception:\n            pass\n\n    return best_sol, best_cost\n\n\ndef assignment_to_lits(assignment):\n    \"\"\"Convert bytearray assignment to signed literal list.\"\"\"\n    return [v if assignment[v] else -v for v in range(1, len(assignment))]\n","numLines":533,"startLine":1,"totalLines":533}}}
