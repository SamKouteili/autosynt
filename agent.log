ts, f'cwls-r{r+1}')\n            current_best = best_cost\n            assignment = bytearray(best_assign)\n            print(f\"    IMPROVED to {best_cost}\")\n    else:\n        # Try walksat-soft to escape\n        remaining2 = min(30, int(270 - (time.time()-t0)))\n        if remaining2 > 5:\n            t1 = time.time()\n            ws_assign, ws_cost = walksat_soft(best_assign, softs, hards, occ, timeout=remaining2)\n            print(f\"    Walksat-soft: {ws_cost} ({time.time()-t1:.1f}s)\")\n            if ws_cost < current_best:\n                sol_lits = assignment_to_lits(ws_assign)\n                viol = check_hard_clauses(sol_lits, hards)\n                if not viol:\n                    update_solution(inst, ws_cost, sol_lits, f'walksat-r{r+1}')\n                    current_best = ws_cost\n            assignment = bytearray(ws_assign)\n\nwith open('experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: cwls+walksat | cost: {current_best} | time: {time.time()-t0:.1f} | notes: haplo-13 deep\\n\")\nPYEOF","description":"Run CWLS on haplotyping-13","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":870,"cache_read_input_tokens":92380,"cache_creation":{"ephemeral_5m_input_tokens":870,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"ab9eb7a8-9a3a-4df4-9f7f-d413a32c6733"}
