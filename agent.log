{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01M5NBEQxjnVdpBpnbzfip7Z","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01SCmcxUNjeRMSqagBaMMHc9","name":"Bash","input":{"command":"python3 -u << 'PYEOF'\n\"\"\"Comprehensive randomized greedy sweep on ALL instances with ratio > 1.05 and <2000 softs.\"\"\"\nimport sys, time, random, csv, gc\nsys.path.insert(0, 'library')\nfrom wcnf_parser import parse_wcnf, check_hard_clauses, evaluate_cost\nfrom solutions import update_solution, get_best_costs\nfrom pysat.solvers import Solver\n\nref = {}\nwith open('benchmarks/max-sat-2024/best-costs.csv') as f:\n    reader = csv.reader(f)\n    next(reader)\n    for row in reader:\n        ref[row[0]] = int(row[1])\n\ncosts = get_best_costs()\ntargets = []\nfor inst, rc in ref.items():\n    if rc <= 0 or inst not in costs: continue\n    ratio = costs[inst] / rc\n    if ratio > 1.05:\n        targets.append((ratio, inst, costs[inst], rc))\ntargets.sort(reverse=True)\n\nt0 = time.time()\nimproved = 0\ntried = 0\n\nfor ratio, inst, cur_cost, ref_cost in targets:\n    if time.time() - t0 > 270:\n        break\n    \n    path = f'benchmarks/max-sat-2024/mse24-anytime-weighted/{inst}'\n    try:\n        data = parse_wcnf(path)\n    except:\n        continue\n    \n    nvars = data['nvars']\n    hards = data['hard_clauses']\n    softs = data['soft_clauses']\n    nsoft = len(softs)\n    \n    # Only process if feasible for randomized greedy\n    # Each trial: nsoft SAT calls, each ~nvars/300000 seconds\n    est_per_trial = nsoft * max(0.001, nvars / 300000)\n    if est_per_trial > 25 or nsoft > 2000:\n        del data; gc.collect()\n        continue\n    \n    current_best = get_best_costs().get(inst, float('inf'))\n    if current_best / ref_cost < 1.05:\n        del data; gc.collect()\n        continue\n    \n    budget = min(max(5, int(est_per_trial * 3)), int(270 - (time.time()-t0)))\n    if budget < 3:\n        del data; gc.collect()\n        break\n    \n    tried += 1\n    t1 = time.time()\n    \n    n_trials = max(3, int(budget / max(0.5, est_per_trial)))\n    \n    for trial in range(min(n_trials, 50)):\n        if time.time() - t1 > budget:\n            break\n        \n        sn = random.choice(['cd19', 'g4'])\n        try:\n            with Solver(name=sn) as sat:\n                for clause in hards:\n                    sat.add_clause(clause)\n                \n                selectors = []\n                for i, (w, clause) in enumerate(softs):\n                    sel = nvars + 1 + i\n                    selectors.append(sel)\n                    sat.add_clause([-sel] + clause)\n                \n                order = list(range(nsoft))\n                random.shuffle(order)\n                \n                must_satisfy = []\n                for idx in order:\n                    if time.time() - t1 > budget:\n                        break\n                    assumptions = must_satisfy + [selectors[idx]]\n                    if sat.solve(assumptions=assumptions):\n                        must_satisfy.append(selectors[idx])\n                \n                if sat.solve(assumptions=must_satisfy):\n                    model = sat.get_model()\n                    sol = [lit for lit in model if abs(lit) <= nvars]\n                    present = set(abs(lit) for lit in sol)\n                    for v in range(1, nvars+1):\n                        if v not in present:\n                            sol.append(v)\n                    cost = evaluate_cost(sol, softs)\n                    \n                    if cost < current_best:\n                        viol = check_hard_clauses(sol, hards)\n                        if not viol:\n                            current_best = cost\n                            update_solution(inst, cost, sol, 'rnd-greedy')\n                            improved += 1\n                            print(f\"IMPROVED: {inst[:50]}: {cur_cost} -> {cost} ({cost/ref_cost:.2f}x)\", flush=True)\n        except:\n            pass\n    \n    del data; gc.collect()\n\nprint(f\"\\nDone. Tried {tried} instances, improved {improved} in {time.time()-t0:.0f}s\", flush=True)\nPYEOF","description":"Comprehensive randomized greedy sweep","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":507,"cache_read_input_tokens":186931,"cache_creation":{"ephemeral_5m_input_tokens":507,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"6db50e0f-fd54-4621-a8f7-9d1f1dda71d5"}
