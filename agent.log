     sol, cost = core_guided_budget(nvars, hards, softs, timeout=remaining, \n                                        solver_name='cd19', conf_budget=budget)\n        elapsed = time.time() - t1\n        \n        if sol and cost and cost < current_best:\n            viol = check_hard_clauses(sol, hards)\n            if not viol:\n                update_solution(inst, cost, sol, f'cgb-{budget}')\n                current_best = cost\n                print(f\"  Budget({budget}): IMPROVED to {cost} ({cost/ref:.2f}x) [{elapsed:.1f}s]\", flush=True)\n        else:\n            pass  # No improvement\n    \n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {short} | approach: cgb-multi | cost: {current_best} | time: {time.time()-t0:.1f} | notes: synplicate cgb\\n\")\nPYEOF","description":"Run core-guided-budget on synplicate instances","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":152345,"cache_read_input_tokens":8629,"cache_creation":{"ephemeral_5m_input_tokens":152345,"ephemeral_1h_input_tokens":0},"output_tokens":25,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"3f0cef4d-4d36-4c24-8a1a-d26f344961ab"}
