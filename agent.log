       if update_solution(inst, cost2, sol2, \"multi-init\"):\n            current_best = cost2\n            print(f\"  -> NEW BEST (multi): {cost2}\")\n\nprint(f\"Done in {time.time()-t0:.1f}s, best={current_best}\")\nwith open('/tmp/agent-sat-1/experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: greedy+multi-init | cost: {current_best} | time: {time.time()-t0:.1f} | notes: lisbon-wedding unsolved attempt\\n\")\nPYEOF\n\n# Also write pa-1 continuation script\ncat > /tmp/solve_pa1_continue.py << 'PYEOF'\n\"\"\"Continue improving relational-inference pa-1\"\"\"\nimport sys, time, signal\nsys.path.insert(0, '/tmp/agent-sat-1')\nsignal.alarm(280)\n\nfrom library.wcnf_parser import parse_wcnf\nfrom library.solvers import build_occurrence_lists, walksat_soft, assignment_to_lits\nfrom library.clause_weight_ls import clause_weight_local_search\nfrom library.solutions import update_solution, load_solutions\n\ninst = \"relational-inference_wt-pa-1.wcnf\"\nbase = \"benchmarks/max-sat-2024/mse24-anytime-weighted/\"\nprint(f\"Working on {inst}\")\nt0 = time.time()\n\ndata = parse_wcnf(base + inst)\nnvars = data['nvars']\nhards = data['hard_clauses']\nsofts = data['soft_clauses']\nprint(f\"nvars={nvars}, nhards={len(hards)}, nsofts={len(softs)}\")\n\nsolutions = load_solutions()\ncurrent_best = solutions[inst]['cost']\nconfig = solutions[inst]['configuration']\nprint(f\"Starting from cost={current_best}\")\n\nassignment = bytearray(nvars + 1)\nfor lit in config:\n    v = abs(lit)\n    if v <= nvars:\n        assignment[v] = 1 if lit > 0 else 0\n\nocc = build_occurrence_lists(nvars, hards, softs)\n\nfor round_num in range(3):\n    remaining = 260 - (time.time() - t0)\n    if remaining < 30:\n        break\n    \n    round_time = min(remaining - 10, 80)\n    print(f\"Round {round_num}: CWLS ({round_time:.0f}s)...\")\n    best_assign, best_cost = clause_weight_local_search(\n        assignment, softs, hards, occ, timeout=round_time, smooth_probability=0.003\n    )\n    if best_cost < current_best:\n        lits = assignment_to_lits(best_assign)\n        if update_solution(inst, best_cost, lits, f\"cwls-cont-r{round_num}\"):\n            current_best = best_cost\n            assignment = bytearray(best_assign)\n            print(f\"  -> {best_cost}\")\n    \n    remaining = 260 - (time.time() - t0)\n    if remaining < 30:\n        break\n    round_time = min(remaining - 10, 80)\n    print(f\"Round {round_num}: walksat-soft ({round_time:.0f}s)...\")\n    best_assign2, best_cost2 = walksat_soft(assignment, softs, hards, occ, timeout=round_time)\n    if best_cost2 < current_best:\n        lits = assignment_to_lits(best_assign2)\n        if update_solution(inst, best_cost2, lits, f\"walksat-cont-r{round_num}\"):\n            current_best = best_cost2\n            assignment = bytearray(best_assign2)\n            print(f\"  -> {best_cost2}\")\n\nprint(f\"Done: best={current_best} in {time.time()-t0:.1f}s\")\nwith open('/tmp/agent-sat-1/experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: cwls+walksat continue | cost: {current_best} | time: {time.time()-t0:.1f} | notes: pa-1 continue\\n\")\nPYEOF\necho \"Ready\"","description":"Write lisbon-wedding and pa-1 solvers"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":773,"cache_read_input_tokens":69420,"cache_creation":{"ephemeral_5m_input_tokens":773,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"38135602-62e8-4094-9f41-0f1fb730f536","uuid":"7b5f3f89-ed2c-44ba-ab78-fc64bcc2dc69"}
