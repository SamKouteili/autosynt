{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013F8keRv3Frbs2kzyuhTJxX","type":"tool_result","content":"     1→\"\"\"Clause-weighting local search for MaxSAT (SATLike-inspired).\n     2→\n     3→Key idea: dynamically adjust clause weights to escape local optima.\n     4→When stuck, increase weights of unsatisfied soft clauses, making them\n     5→more attractive to satisfy. Periodically smooth weights back toward\n     6→original values to prevent weight explosion.\n     7→\n     8→This is one of the most effective incomplete MaxSAT techniques,\n     9→used by competition winners like SATLike, NuWLS, etc.\n    10→\"\"\"\n    11→\n    12→import random\n    13→import time\n    14→from library.solvers import (build_occurrence_lists, compute_sat_counts,\n    15→                              flip_variable, flip_preserves_hard, assignment_to_lits)\n    16→\n    17→\n    18→def clause_weight_local_search(assignment, soft_clauses, hard_clauses, occ_lists,\n    19→                                timeout=240, smooth_probability=0.01, weight_inc=1):\n    20→    \"\"\"Clause-weighting local search for MaxSAT.\n    21→\n    22→    At each step:\n    23→    1. Pick a random unsatisfied soft clause\n    24→    2. Find the best variable to flip in that clause (preserving hard feasibility)\n    25→    3. If no improving flip exists, increase weights of all unsatisfied soft clauses\n    26→    4. With some probability, smooth weights back toward original values\n    27→\n    28→    Args:\n    29→        assignment: bytearray, initial feasible assignment\n    30→        soft_clauses: list of (weight, clause)\n    31→        hard_clauses: list of clauses\n    32→        occ_lists: from build_occurrence_lists\n    33→        timeout: seconds\n    34→        smooth_probability: probability of smoothing per non-improving step\n    35→        weight_inc: weight increment for unsatisfied clauses\n    36→\n    37→    Returns (best_assignment, best_cost) using ORIGINAL weights.\n    38→    \"\"\"\n    39→    hard_pos, hard_neg, soft_pos, soft_neg, soft_weights_orig, soft_vars = occ_lists\n    40→    nvars = len(assignment) - 1\n    41→    nsoft = len(soft_clauses)\n    42→\n    43→    # Dynamic weights (start from original)\n    44→    dyn_weights = list(soft_weights_orig)\n    45→\n    46→    hard_sat_count, soft_sat_count = compute_sat_counts(assignment, hard_clauses, soft_clauses)\n    47→\n    48→    # Track original cost\n    49→    orig_cost = sum(soft_weights_orig[i] for i in range(nsoft) if soft_sat_count[i] == 0)\n    50→    best_cost = orig_cost\n    51→    best_assign = bytearray(assignment)\n    52→\n    53→    # Score array: delta in dynamic weight if we flip v\n    54→    # score[v] = sum of dyn_weights of soft clauses that would become satisfied\n    55→    #          - sum of dyn_weights of soft clauses that would become unsatisfied\n    56→    score = [0] * (nvars + 1)\n    57→    for v in soft_vars:\n    58→        s = 0\n    59→        if assignment[v]:\n    60→            for ci in soft_pos[v]:\n    61→                if soft_sat_count[ci] == 1: s += dyn_weights[ci]\n    62→            for ci in soft_neg[v]:\n    63→                if soft_sat_count[ci] == 0: s -= dyn_weights[ci]\n    64→        else:\n    65→            for ci in soft_pos[v]:\n    66→                if soft_sat_count[ci] == 0: s -= dyn_weights[ci]\n    67→            for ci in soft_neg[v]:\n    68→                if soft_sat_count[ci] == 1: s += dyn_weights[ci]\n    69→        score[v] = s\n    70→\n    71→    t0 = time.time()\n    72→    steps = 0\n    73→\n    74→    while time.time() - t0 < timeout:\n    75→        # Find unsatisfied soft clauses\n    76→        unsat = [i for i in range(nsoft) if soft_sat_count[i] == 0]\n    77→        if not unsat:\n    78→            break\n    79→\n    80→        # Pick random unsatisfied soft clause\n    81→        ci = random.choice(unsat)\n    82→        w_orig, clause = soft_clauses[ci]\n    83→\n    84→        # Find best variable to flip in this clause\n    85→        best_v = -1\n    86→        best_score = float('inf')\n    87→\n    88→        for lit in clause:\n    89→            v = abs(lit)\n    90→            # Check if flipping v would satisfy this clause\n    91→            would_satisfy = (lit > 0 and not assignment[v]) or (lit < 0 and assignment[v])\n    92→            if not would_satisfy:\n    93→                continue\n    94→            if not flip_preserves_hard(v, assignment, hard_pos, hard_neg, hard_sat_count):\n    95→                continue\n    96→            if score[v] < best_score:\n    97→                best_score = score[v]\n    98→                best_v = v\n    99→\n   100→        if best_v != -1 and best_score < 0:\n   101→            # Improving flip found - do it\n   102→            _do_flip(best_v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n   103→                    hard_sat_count, soft_sat_count, dyn_weights, score, soft_clauses)\n   104→\n   105→            # Check original cost\n   106→            orig_cost_new = sum(soft_weights_orig[i] for i in range(nsoft) if soft_sat_count[i] == 0)\n   107→            if orig_cost_new < best_cost:\n   108→                best_cost = orig_cost_new\n   109→                best_assign = bytearray(assignment)\n   110→            steps += 1\n   111→        elif best_v != -1:\n   112→            # Non-improving but feasible flip - do it anyway (exploration)\n   113→            _do_flip(best_v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n   114→                    hard_sat_count, soft_sat_count, dyn_weights, score, soft_clauses)\n   115→\n   116→            orig_cost_new = sum(soft_weights_orig[i] for i in range(nsoft) if soft_sat_count[i] == 0)\n   117→            if orig_cost_new < best_cost:\n   118→                best_cost = orig_cost_new\n   119→                best_assign = bytearray(assignment)\n   120→            steps += 1\n   121→\n   122→            # Increase weights of unsatisfied clauses\n   123→            for ui in unsat:\n   124→                old_w = dyn_weights[ui]\n   125→                dyn_weights[ui] = old_w + weight_inc\n   126→                diff = weight_inc\n   127→                # Update scores for variables in this clause\n   128→                _, ucl = soft_clauses[ui]\n   129→                for lit in ucl:\n   130→                    vv = abs(lit)\n   131→                    would_satisfy = (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv])\n   132→                    if would_satisfy:\n   133→                        score[vv] -= diff  # More incentive to flip\n   134→                    else:\n   135→                        pass  # Doesn't affect score since clause is already unsat\n   136→\n   137→            # Smooth weights with probability\n   138→            if random.random() < smooth_probability:\n   139→                for i in range(nsoft):\n   140→                    if dyn_weights[i] > soft_weights_orig[i]:\n   141→                        old_w = dyn_weights[i]\n   142→                        dyn_weights[i] = max(soft_weights_orig[i], dyn_weights[i] - 1)\n   143→                        if dyn_weights[i] != old_w:\n   144→                            diff = dyn_weights[i] - old_w  # negative\n   145→                            if soft_sat_count[i] == 0:\n   146→                                _, cl = soft_clauses[i]\n   147→                                for lit in cl:\n   148→                                    vv = abs(lit)\n   149→                                    would_satisfy = (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv])\n   150→                                    if would_satisfy:\n   151→                                        score[vv] -= diff\n   152→        else:\n   153→            # No feasible flip in this clause, just increase weights\n   154→            for ui in unsat:\n   155→                old_w = dyn_weights[ui]\n   156→                dyn_weights[ui] = old_w + weight_inc\n   157→                diff = weight_inc\n   158→                _, ucl = soft_clauses[ui]\n   159→                for lit in ucl:\n   160→                    vv = abs(lit)\n   161→                    would_satisfy = (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv])\n   162→                    if would_satisfy:\n   163→                        score[vv] -= diff\n   164→\n   165→    return best_assign, best_cost\n   166→\n   167→\n   168→def _do_flip(v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n   169→             hard_sat_count, soft_sat_count, dyn_weights, score, soft_clauses):\n   170→    \"\"\"Flip v and update scores incrementally.\"\"\"\n   171→    # Update scores for neighbors before flipping\n   172→    if assignment[v]:\n   173→        # v going from 1 to 0\n   174→        for ci in soft_pos[v]:\n   175→            w = dyn_weights[ci]\n   176→            if soft_sat_count[ci] == 1:\n   177→                # This clause becomes unsatisfied\n   178→                for lit in soft_clauses[ci][1]:\n   179→                    vv = abs(lit)\n   180→                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n   181→                        score[vv] -= w  # Now they can satisfy it\n   182→            elif soft_sat_count[ci] == 2:\n   183→                for lit in soft_clauses[ci][1]:\n   184→                    vv = abs(lit)\n   185→                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n   186→                        score[vv] += w  # They become the only satisfier\n   187→                        break\n   188→        for ci in soft_neg[v]:\n   189→            w = dyn_weights[ci]\n   190→            if soft_sat_count[ci] == 0:\n   191→                for lit in soft_clauses[ci][1]:\n   192→                    vv = abs(lit)\n   193→                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n   194→                        score[vv] += w\n   195→            elif soft_sat_count[ci] == 1:\n   196→                for lit in soft_clauses[ci][1]:\n   197→                    vv = abs(lit)\n   198→                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n   199→                        score[vv] -= w\n   200→                        break\n   201→    else:\n   202→        # v going from 0 to 1\n   203→        for ci in soft_pos[v]:\n   204→            w = dyn_weights[ci]\n   205→            if soft_sat_count[ci] == 0:\n   206→                for lit in soft_clauses[ci][1]:\n   207→                    vv = abs(lit)\n   208→                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n   209→                        score[vv] += w\n   210→            elif soft_sat_count[ci] == 1:\n   211→                for lit in soft_clauses[ci][1]:\n   212→                    vv = abs(lit)\n   213→                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n   214→                        score[vv] -= w\n   215→                        break\n   216→        for ci in soft_neg[v]:\n   217→            w = dyn_weights[ci]\n   218→            if soft_sat_count[ci] == 1:\n   219→                for lit in soft_clauses[ci][1]:\n   220→                    vv = abs(lit)\n   221→                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n   222→                        score[vv] -= w\n   223→            elif soft_sat_count[ci] == 2:\n   224→                for lit in soft_clauses[ci][1]:\n   225→                    vv = abs(lit)\n   226→                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n   227→                        score[vv] += w\n   228→                        break\n   229→\n   230→    # Now flip\n   231→    flip_variable(v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n   232→                  hard_sat_count, soft_sat_count)\n   233→\n   234→    # Recompute score[v] from scratch\n   235→    s = 0\n   236→    if assignment[v]:\n   237→        for ci in soft_pos[v]:\n   238→            if soft_sat_count[ci] == 1: s += dyn_weights[ci]\n   239→        for ci in soft_neg[v]:\n   240→            if soft_sat_count[ci] == 0: s -= dyn_weights[ci]\n   241→    else:\n   242→        for ci in soft_pos[v]:\n   243→            if soft_sat_count[ci] == 0: s -= dyn_weights[ci]\n   244→        for ci in soft_neg[v]:\n   245→            if soft_sat_count[ci] == 1: s += dyn_weights[ci]\n   246→    score[v] = s\n   247→"}]},"parent_tool_use_id":null,"session_id":"38135602-62e8-4094-9f41-0f1fb730f536","uuid":"7aeb1a87-e708-45fc-bf6c-1aa7bbe711c9","tool_use_result":{"type":"text","file":{"filePath":"/tmp/agent-sat-1/library/clause_weight_ls.py","content":"\"\"\"Clause-weighting local search for MaxSAT (SATLike-inspired).\n\nKey idea: dynamically adjust clause weights to escape local optima.\nWhen stuck, increase weights of unsatisfied soft clauses, making them\nmore attractive to satisfy. Periodically smooth weights back toward\noriginal values to prevent weight explosion.\n\nThis is one of the most effective incomplete MaxSAT techniques,\nused by competition winners like SATLike, NuWLS, etc.\n\"\"\"\n\nimport random\nimport time\nfrom library.solvers import (build_occurrence_lists, compute_sat_counts,\n                              flip_variable, flip_preserves_hard, assignment_to_lits)\n\n\ndef clause_weight_local_search(assignment, soft_clauses, hard_clauses, occ_lists,\n                                timeout=240, smooth_probability=0.01, weight_inc=1):\n    \"\"\"Clause-weighting local search for MaxSAT.\n\n    At each step:\n    1. Pick a random unsatisfied soft clause\n    2. Find the best variable to flip in that clause (preserving hard feasibility)\n    3. If no improving flip exists, increase weights of all unsatisfied soft clauses\n    4. With some probability, smooth weights back toward original values\n\n    Args:\n        assignment: bytearray, initial feasible assignment\n        soft_clauses: list of (weight, clause)\n        hard_clauses: list of clauses\n        occ_lists: from build_occurrence_lists\n        timeout: seconds\n        smooth_probability: probability of smoothing per non-improving step\n        weight_inc: weight increment for unsatisfied clauses\n\n    Returns (best_assignment, best_cost) using ORIGINAL weights.\n    \"\"\"\n    hard_pos, hard_neg, soft_pos, soft_neg, soft_weights_orig, soft_vars = occ_lists\n    nvars = len(assignment) - 1\n    nsoft = len(soft_clauses)\n\n    # Dynamic weights (start from original)\n    dyn_weights = list(soft_weights_orig)\n\n    hard_sat_count, soft_sat_count = compute_sat_counts(assignment, hard_clauses, soft_clauses)\n\n    # Track original cost\n    orig_cost = sum(soft_weights_orig[i] for i in range(nsoft) if soft_sat_count[i] == 0)\n    best_cost = orig_cost\n    best_assign = bytearray(assignment)\n\n    # Score array: delta in dynamic weight if we flip v\n    # score[v] = sum of dyn_weights of soft clauses that would become satisfied\n    #          - sum of dyn_weights of soft clauses that would become unsatisfied\n    score = [0] * (nvars + 1)\n    for v in soft_vars:\n        s = 0\n        if assignment[v]:\n            for ci in soft_pos[v]:\n                if soft_sat_count[ci] == 1: s += dyn_weights[ci]\n            for ci in soft_neg[v]:\n                if soft_sat_count[ci] == 0: s -= dyn_weights[ci]\n        else:\n            for ci in soft_pos[v]:\n                if soft_sat_count[ci] == 0: s -= dyn_weights[ci]\n            for ci in soft_neg[v]:\n                if soft_sat_count[ci] == 1: s += dyn_weights[ci]\n        score[v] = s\n\n    t0 = time.time()\n    steps = 0\n\n    while time.time() - t0 < timeout:\n        # Find unsatisfied soft clauses\n        unsat = [i for i in range(nsoft) if soft_sat_count[i] == 0]\n        if not unsat:\n            break\n\n        # Pick random unsatisfied soft clause\n        ci = random.choice(unsat)\n        w_orig, clause = soft_clauses[ci]\n\n        # Find best variable to flip in this clause\n        best_v = -1\n        best_score = float('inf')\n\n        for lit in clause:\n            v = abs(lit)\n            # Check if flipping v would satisfy this clause\n            would_satisfy = (lit > 0 and not assignment[v]) or (lit < 0 and assignment[v])\n            if not would_satisfy:\n                continue\n            if not flip_preserves_hard(v, assignment, hard_pos, hard_neg, hard_sat_count):\n                continue\n            if score[v] < best_score:\n                best_score = score[v]\n                best_v = v\n\n        if best_v != -1 and best_score < 0:\n            # Improving flip found - do it\n            _do_flip(best_v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n                    hard_sat_count, soft_sat_count, dyn_weights, score, soft_clauses)\n\n            # Check original cost\n            orig_cost_new = sum(soft_weights_orig[i] for i in range(nsoft) if soft_sat_count[i] == 0)\n            if orig_cost_new < best_cost:\n                best_cost = orig_cost_new\n                best_assign = bytearray(assignment)\n            steps += 1\n        elif best_v != -1:\n            # Non-improving but feasible flip - do it anyway (exploration)\n            _do_flip(best_v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n                    hard_sat_count, soft_sat_count, dyn_weights, score, soft_clauses)\n\n            orig_cost_new = sum(soft_weights_orig[i] for i in range(nsoft) if soft_sat_count[i] == 0)\n            if orig_cost_new < best_cost:\n                best_cost = orig_cost_new\n                best_assign = bytearray(assignment)\n            steps += 1\n\n            # Increase weights of unsatisfied clauses\n            for ui in unsat:\n                old_w = dyn_weights[ui]\n                dyn_weights[ui] = old_w + weight_inc\n                diff = weight_inc\n                # Update scores for variables in this clause\n                _, ucl = soft_clauses[ui]\n                for lit in ucl:\n                    vv = abs(lit)\n                    would_satisfy = (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv])\n                    if would_satisfy:\n                        score[vv] -= diff  # More incentive to flip\n                    else:\n                        pass  # Doesn't affect score since clause is already unsat\n\n            # Smooth weights with probability\n            if random.random() < smooth_probability:\n                for i in range(nsoft):\n                    if dyn_weights[i] > soft_weights_orig[i]:\n                        old_w = dyn_weights[i]\n                        dyn_weights[i] = max(soft_weights_orig[i], dyn_weights[i] - 1)\n                        if dyn_weights[i] != old_w:\n                            diff = dyn_weights[i] - old_w  # negative\n                            if soft_sat_count[i] == 0:\n                                _, cl = soft_clauses[i]\n                                for lit in cl:\n                                    vv = abs(lit)\n                                    would_satisfy = (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv])\n                                    if would_satisfy:\n                                        score[vv] -= diff\n        else:\n            # No feasible flip in this clause, just increase weights\n            for ui in unsat:\n                old_w = dyn_weights[ui]\n                dyn_weights[ui] = old_w + weight_inc\n                diff = weight_inc\n                _, ucl = soft_clauses[ui]\n                for lit in ucl:\n                    vv = abs(lit)\n                    would_satisfy = (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv])\n                    if would_satisfy:\n                        score[vv] -= diff\n\n    return best_assign, best_cost\n\n\ndef _do_flip(v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n             hard_sat_count, soft_sat_count, dyn_weights, score, soft_clauses):\n    \"\"\"Flip v and update scores incrementally.\"\"\"\n    # Update scores for neighbors before flipping\n    if assignment[v]:\n        # v going from 1 to 0\n        for ci in soft_pos[v]:\n            w = dyn_weights[ci]\n            if soft_sat_count[ci] == 1:\n                # This clause becomes unsatisfied\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n                        score[vv] -= w  # Now they can satisfy it\n            elif soft_sat_count[ci] == 2:\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n                        score[vv] += w  # They become the only satisfier\n                        break\n        for ci in soft_neg[v]:\n            w = dyn_weights[ci]\n            if soft_sat_count[ci] == 0:\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n                        score[vv] += w\n            elif soft_sat_count[ci] == 1:\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n                        score[vv] -= w\n                        break\n    else:\n        # v going from 0 to 1\n        for ci in soft_pos[v]:\n            w = dyn_weights[ci]\n            if soft_sat_count[ci] == 0:\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n                        score[vv] += w\n            elif soft_sat_count[ci] == 1:\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n                        score[vv] -= w\n                        break\n        for ci in soft_neg[v]:\n            w = dyn_weights[ci]\n            if soft_sat_count[ci] == 1:\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if (lit > 0 and not assignment[vv]) or (lit < 0 and assignment[vv]):\n                        score[vv] -= w\n            elif soft_sat_count[ci] == 2:\n                for lit in soft_clauses[ci][1]:\n                    vv = abs(lit)\n                    if vv != v and ((lit > 0 and assignment[vv]) or (lit < 0 and not assignment[vv])):\n                        score[vv] += w\n                        break\n\n    # Now flip\n    flip_variable(v, assignment, hard_pos, hard_neg, soft_pos, soft_neg,\n                  hard_sat_count, soft_sat_count)\n\n    # Recompute score[v] from scratch\n    s = 0\n    if assignment[v]:\n        for ci in soft_pos[v]:\n            if soft_sat_count[ci] == 1: s += dyn_weights[ci]\n        for ci in soft_neg[v]:\n            if soft_sat_count[ci] == 0: s -= dyn_weights[ci]\n    else:\n        for ci in soft_pos[v]:\n            if soft_sat_count[ci] == 0: s -= dyn_weights[ci]\n        for ci in soft_neg[v]:\n            if soft_sat_count[ci] == 1: s += dyn_weights[ci]\n    score[v] = s\n","numLines":247,"startLine":1,"totalLines":247}}}
