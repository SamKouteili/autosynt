{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016fNwbeoN8jXAb7UjfBMBEm","type":"tool_result","content":"     1→\"\"\"Batch solver: solve multiple instances in parallel using multiprocessing.\"\"\"\n     2→\n     3→import csv\n     4→import json\n     5→import sys\n     6→import time\n     7→from pathlib import Path\n     8→from concurrent.futures import ProcessPoolExecutor, as_completed\n     9→from datetime import datetime, timezone\n    10→\n    11→# Paths\n    12→ROOT = Path(__file__).resolve().parent.parent\n    13→INSTANCES_DIR = ROOT / \"benchmarks\" / \"syntcomp-2025\" / \"instances\"\n    14→REFERENCE_CSV = ROOT / \"benchmarks\" / \"syntcomp-2025\" / \"reference.csv\"\n    15→EXPERIMENTS_LOG = ROOT / \"experiments.log\"\n    16→\n    17→\n    18→def load_reference():\n    19→    \"\"\"Load reference.csv into dict keyed by instance name.\"\"\"\n    20→    with open(REFERENCE_CSV) as f:\n    21→        return {r['instance']: r for r in csv.DictReader(f)}\n    22→\n    23→\n    24→def get_unsolved(reference, solutions):\n    25→    \"\"\"Get list of unsolved instance names.\"\"\"\n    26→    return [name for name in reference if name not in solutions]\n    27→\n    28→\n    29→def get_improvable(reference, solutions):\n    30→    \"\"\"Get realizable instances where we might improve AND gate count.\"\"\"\n    31→    improvable = []\n    32→    for name, sol in solutions.items():\n    33→        if sol['status'] == 'realizable':\n    34→            ref = reference.get(name, {})\n    35→            ref_size = int(ref.get('ref_size', -1))\n    36→            if ref_size >= 0 and sol['and_gates'] > ref_size:\n    37→                improvable.append((name, sol['and_gates'], ref_size))\n    38→    return sorted(improvable, key=lambda x: x[1] - x[2], reverse=True)\n    39→\n    40→\n    41→def solve_one(instance_name, timeout=120):\n    42→    \"\"\"Solve a single instance. Must be picklable for multiprocessing.\"\"\"\n    43→    from library.synth import solve_instance\n    44→    tlsf_path = INSTANCES_DIR / f\"{instance_name}.tlsf\"\n    45→    if not tlsf_path.exists():\n    46→        return instance_name, {'status': 'error', 'error': 'File not found', 'time': 0}\n    47→    result = solve_instance(tlsf_path, timeout=timeout)\n    48→    return instance_name, result\n    49→\n    50→\n    51→def log_experiment(instance, result):\n    52→    \"\"\"Append to experiments.log.\"\"\"\n    53→    ts = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n    54→    status = result['status']\n    55→    gates = result.get('and_gates', -1)\n    56→    gates_str = str(gates) if gates >= 0 else 'N/A'\n    57→    elapsed = result.get('time', 0)\n    58→    method = result.get('method', '?')\n    59→    error = result.get('error', '')\n    60→    notes = f\"{method}\" + (f\" | error: {error}\" if error else \"\")\n    61→    line = f\"[{ts}] instance: {instance} | approach: {method} | status: {status} | and_gates: {gates_str} | time: {elapsed:.1f}s | notes: {notes}\\n\"\n    62→    with open(EXPERIMENTS_LOG, \"a\") as f:\n    63→        f.write(line)\n    64→\n    65→\n    66→def batch_solve(instance_names, timeout=120, max_workers=8):\n    67→    \"\"\"Solve instances in parallel, updating solutions as we go.\"\"\"\n    68→    sys.path.insert(0, str(ROOT))\n    69→    from library.solutions import load_solutions, update_solution, mark_unrealizable\n    70→\n    71→    total = len(instance_names)\n    72→    solved = 0\n    73→    new_solved = 0\n    74→    errors = 0\n    75→\n    76→    print(f\"Batch solving {total} instances with {max_workers} workers, timeout={timeout}s\")\n    77→\n    78→    with ProcessPoolExecutor(max_workers=max_workers) as executor:\n    79→        futures = {\n    80→            executor.submit(solve_one, name, timeout): name\n    81→            for name in instance_names\n    82→        }\n    83→\n    84→        for future in as_completed(futures):\n    85→            name = futures[future]\n    86→            try:\n    87→                _, result = future.result(timeout=timeout + 30)\n    88→                solved += 1\n    89→                log_experiment(name, result)\n    90→\n    91→                if result['status'] == 'realizable':\n    92→                    if update_solution(name, 'realizable', result['aiger'], result['method']):\n    93→                        new_solved += 1\n    94→                        gates = result['and_gates']\n    95→                        print(f\"  [+] {name}: REALIZABLE ({gates} gates) [{result['time']:.1f}s]\")\n    96→                elif result['status'] == 'unrealizable':\n    97→                    if mark_unrealizable(name, result['method']):\n    98→                        new_solved += 1\n    99→                        print(f\"  [+] {name}: UNREALIZABLE [{result['time']:.1f}s]\")\n   100→                elif result['status'] == 'timeout':\n   101→                    pass  # silent on timeout\n   102→                else:\n   103→                    errors += 1\n   104→                    if result.get('error'):\n   105→                        print(f\"  [!] {name}: {result['error'][:80]}\")\n   106→\n   107→                if solved % 50 == 0:\n   108→                    print(f\"  Progress: {solved}/{total} done, {new_solved} new solutions\")\n   109→\n   110→            except Exception as e:\n   111→                errors += 1\n   112→                solved += 1\n   113→\n   114→    print(f\"\\nDone: {solved}/{total} attempted, {new_solved} new solutions, {errors} errors\")\n   115→    return new_solved\n   116→\n   117→\n   118→if __name__ == \"__main__\":\n   119→    import argparse\n   120→    parser = argparse.ArgumentParser()\n   121→    parser.add_argument(\"--timeout\", type=int, default=120)\n   122→    parser.add_argument(\"--workers\", type=int, default=8)\n   123→    parser.add_argument(\"--family\", type=str, default=None)\n   124→    parser.add_argument(\"--status-filter\", typ