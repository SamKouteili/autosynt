{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019sj4LHhPAW9EDEeAPCHTv4","type":"tool_result","content":"     1→\"\"\"Core-guided MaxSAT solver for instances with unit soft clauses.\n     2→\n     3→Uses SAT solver assumptions to iteratively find and relax unsatisfiable cores.\n     4→Only works when all soft clauses are unit (single literal). For such instances,\n     5→this is dramatically more effective than local search — e.g. timetabling comp07.lp\n     6→went from 1778x to optimal.\n     7→\"\"\"\n     8→\n     9→import time\n    10→\n    11→from pysat.solvers import Solver\n    12→try:\n    13→    from library.wcnf_parser import evaluate_cost\n    14→    from library.solvers import sat_solve_with_timeout, SolverTimeout\n    15→except ImportError:\n    16→    from wcnf_parser import evaluate_cost\n    17→    from solvers import sat_solve_with_timeout, SolverTimeout\n    18→\n    19→\n    20→def core_guided_solve(nvars, hard_clauses, soft_clauses, timeout=240, solver_name='cd19'):\n    21→    \"\"\"Naive core-guided solver — excludes all core literals. Fast but suboptimal.\"\"\"\n    22→    soft_lits = []\n    23→    for w, clause in soft_clauses:\n    24→        if len(clause) != 1:\n    25→            return None, None\n    26→        soft_lits.append((w, clause[0]))\n    27→\n    28→    soft_lits.sort(key=lambda x: x[0], reverse=True)\n    29→    t0 = time.time()\n    30→\n    31→    with Solver(name=solver_name) as sat:\n    32→        for clause in hard_clauses:\n    33→            sat.add_clause(clause)\n    34→\n    35→        excluded = set()\n    36→        best_sol = None\n    37→        best_cost = float('inf')\n    38→\n    39→        while time.time() - t0 < timeout:\n    40→            assumptions = [lit for _, lit in soft_lits if lit not in excluded]\n    41→            remaining = max(1, int(timeout - (time.time() - t0)))\n    42→            try:\n    43→                result = sat_solve_with_timeout(sat, assumptions=assumptions, timeout=remaining)\n    44→            except SolverTimeout:\n    45→                break\n    46→            if result:\n    47→                model = sat.get_model()\n    48→                sol = [lit for lit in model if abs(lit) <= nvars]\n    49→                present = set(abs(lit) for lit in sol)\n    50→                for v in range(1, nvars + 1):\n    51→                    if v not in present:\n    52→                        sol.append(v)\n    53→                cost = evaluate_cost(sol, soft_clauses)\n    54→                if cost < best_cost:\n    55→                    best_cost = cost\n    56→                    best_sol = sol\n    57→                break\n    58→            else:\n    59→                core = sat.get_core()\n    60→                if not core:\n    61→                    break\n    62→                excluded.update(core)\n    63→\n    64→    return best_sol, best_cost\n    65→\n    66→\n    67→def core_guided_budget(nvars, hard_clauses, soft_clauses, timeout=60,\n    68→                       solver_name='cd19', conf_budget=100000):\n    69→    \"\"\"Core-guided solver with conflict budget — handles hard SAT instances.\n    70→\n    71→    When a SAT call exceeds the conflict budget, drops the lightest remaining\n    72→    assumption instead of hanging. This is dramatically more effective than\n    73→    naive core-guided on instances where some SAT calls hang (e.g. synplicate).\n    74→\n    75→    Game-changer results:\n    76→    - synplicate size11 arity3/f3: 535→194 (4.25x→1.54x)\n    77→    - synplicate dag_run2_16: 819→333 (2.06x→0.84x, BEATS REFERENCE)\n    78→    \"\"\"\n    79→    soft_lits = []\n    80→    for w, clause in soft_clauses:\n    81→        if len(clause) != 1:\n    82→            return None, None\n    83→        soft_lits.append((w, clause[0]))\n    84→\n    85→    soft_lits.sort(key=lambda x: x[0], reverse=True)\n    86→    t0 = time.time()\n    87→\n    88→    with Solver(name=solver_name) as sat:\n    89→        for clause in hard_clauses:\n    90→            sat.add_clause(clause)\n    91→\n    92→        excluded = set()\n    93→        best_sol = None\n    94→        best_cost = float('inf')\n    95→\n    96→        for iteration in range(len(soft_lits) * 2):\n    97→            if time.time() - t0 > timeout:\n    98→                break\n    99→            assumptions = [lit for _, lit in soft_lits if lit not in excluded]\n   100→            if not assumptions:\n   101→                break\n   102→\n   103→            sat.conf_budget(conf_budget)\n   104→            result = sat.solve_limited(assumptions=assumptions, expect_interrupt=True)\n   105→\n   106→            if result is True:\n   107→                model = sat.get_model()\n   108→                sol = [lit for lit in model if abs(lit) <= nvars]\n   109→                present = set(abs(lit) for lit in sol)\n   110→                for v in range(1, nvars + 1):\n   111→                    if v not in present:\n   112→                        sol.append(v)\n   113→                cost = evaluate_cost(sol, soft_clauses)\n   114→                if cost < best_cost:\n   115→                    best_cost = cost\n   116→                    best_sol = sol\n   117→                break\n   118→            elif result is False:\n   119→                core = sat.get_core()\n   120→                if not core:\n   121→                    break\n   122→                excluded.update(core)\n   123→            else:\n   124→                # Budget exceeded — drop lightest remaining assumption\n   125→                remaining = [(w, lit) for w, lit in soft_lits if lit not in excluded]\n   126→                if not remaining:\n   127→                    break\n   128→                _, lightest = min(remaining, key=lambda x: x[0])\n   129→                excluded.add(lightest)\n   130→\n   131→    return best_sol, best_cost\n   132→\n   133→\n   134→def wpm1_solve(nvars, hard_clauses, soft_clauses, timeout=240, solver_name='cd19'):\n   135→    \"\"\"WPM1-style core-guided solver with proper relaxation variables.\n   136→\n   137→    Instead of excluding all core literals (naive approach), adds relaxation:\n   138→    - For each core, find min weight and subtract from all core members\n   139→    - Add at-most-one relaxation constraint\n   140→    - Zero-weight assumptions are removed\n   141→\n   142→    Much better quality than naive core-guided, especially for weighted instances.\n   143→    \"\"\"\n   144→    soft_lits = []\n   145→    for w, clause in soft_clauses:\n   146→        if len(clause) != 1:\n   147→            return None, None\n   148→        soft_lits.append((w, clause[0]))\n   149→\n   150→    t0 = time.time()\n   151→    next_var = nvars + 1\n   152→\n   153→    with Solver(name=solver_name) as sat:\n   154→        for clause in hard_clauses:\n   155→            sat.add_clause(clause)\n   156→\n   157→        # Active assumptions: {assumption_lit: weight}\n   158→        active = {}\n   159→        for w, lit in soft_lits:\n   160→            if lit in active:\n   161→                active[lit] = active[lit] + w\n   162→            else:\n   163→                active[lit] = w\n   164→\n   165→        lower_bound = 0\n   166→        best_sol = None\n   167→        best_cost = float('inf')\n   168→        iterations = 0\n   169→\n   170→        while time.time() - t0 < timeout:\n   171→            iterations += 1\n   172→            assumptions = list(active.keys())\n   173→\n   174→            if sat.solve(assumptions=assumptions):\n   175→                model = sat.get_model()\n   176→                sol = [lit for lit in model if abs(lit) <= nvars]\n   177→                present = set(abs(lit) for lit in sol)\n   178→                for v in range(1, nvars + 1):\n   179→                    if v not in present:\n   180→                        sol.append(v)\n   181→                cost = evaluate_cost(sol, soft_clauses)\n   182→                if cost < best_cost:\n   183→                    best_cost = cost\n   184→                    best_sol = sol\n   185→                break\n   186→            else:\n   187→                core = sat.get_core()\n   188→                if not core:\n   189→                    break\n   190→                core_set = set(core)\n   191→\n   192→                # Find minimum weight in core\n   193→                min_w = min(active[lit] for lit in core if lit in active)\n   194→                lower_bound += min_w\n   195→\n   196→                # Relaxation variables for this core\n   197→                relax_vars = []\n   198→                for lit in core:\n   199→                    if lit not in active:\n   200→                        continue\n   201→                    w = active[lit]\n   202→                    del active[lit]\n   203→\n   204→                    remaining_w = w - min_w\n   205→                    if remaining_w > 0:\n   206→                        # Split: keep original lit with remaining weight\n   207→                        active[lit] = remaining_w\n   208→\n   209→                    # Create relaxation variable\n   210→                    r = next_var\n   211→                    next_var += 1\n   212→                    relax_vars.append(r)\n   213→\n   214→                    # lit OR r must be true (if lit is falsified, r must be true)\n   215→                    sat.add_clause([lit, r])\n   216→\n   217→                # At most one relaxation variable can be true (exactly one lit in core is relaxed)\n   218→                # Encode as: at-least-one + pairwise at-most-one\n   219→                if len(relax_vars) > 1:\n   220→                    # At least one relaxation (the core says at least one assumption must be false)\n   221→                    sat.add_clause(relax_vars)\n   222→                    # Pairwise at-most-one (for small cores)\n   223→                    if len(relax_vars) <= 20:\n   224→                        for i in range(len(relax_vars)):\n   225→                            for j in range(i + 1, len(relax_vars)):\n   226→                                sat.add_clause([-relax_vars[i], -relax_vars[j]])\n   227→                    else:\n   228→                        # For large cores, use sequential counter encoding\n   229→                        _encode_at_most_one_sequential(sat, relax_vars, next_var)\n   230→                        next_var += len(relax_vars) - 1\n   231→                elif len(relax_vars) == 1:\n   232→                    sat.add_clause(relax_vars)\n   233→\n   234→    return best_sol, best_cost\n   235→\n   236→\n   237→def _encode_at_most_one_sequential(sat, lits, start_var):\n   238→    \"\"\"Encode at-most-one constraint using sequential counter (linear clauses).\"\"\"\n   239→    n = len(lits)\n   240→    if n <= 1:\n   241→        return\n   242→    # Auxiliary vars: s_1, ..., s_{n-1}\n   243→    s = [start_var + i for i in range(n - 1)]\n   244→    # x_0 => s_0\n   245→    sat.add_clause([-lits[0], s[0]])\n   246→    for i in range(1, n - 1):\n   247→        # x_i => s_i\n   248→        sat.add_clause([-lits[i], s[i]])\n   249→        # s_{i-1} => s_i\n   250→        sat.add_clause([-s[i - 1], s[i]])\n   251→        # x_i and s_{i-1} can't both be true\n   252→        sat.add_clause([-lits[i], -s[i - 1]])\n   253→    # x_{n-1} and s_{n-2} can't both be true\n   254→    sat.add_clause([-lits[n - 1], -s[n - 2]])\n   255→"}]},"parent_tool_use_id":null,"session_id":"38135602-62e8-4094-9f41-0f1fb730f536","uuid":"abf18f93-4871-4c2d-b83f-33b5983d3ad4","tool_use_result":{"type":"text","file":{"filePath":"/tmp/agent-sat-1/library/core_guided.py","content":"\"\"\"Core-guided MaxSAT solver for instances with unit soft clauses.\n\nUses SAT solver assumptions to iteratively find and relax unsatisfiable cores.\nOnly works when all soft clauses are unit (single literal). For such instances,\nthis is dramatically more effective than local search — e.g. timetabling comp07.lp\nwent from 1778x to optimal.\n\"\"\"\n\nimport time\n\nfrom pysat.solvers import Solver\ntry:\n    from library.wcnf_parser import evaluate_cost\n    from library.solvers import sat_solve_with_timeout, SolverTimeout\nexcept ImportError:\n    from wcnf_parser import evaluate_cost\n    from solvers import sat_solve_with_timeout, SolverTimeout\n\n\ndef core_guided_solve(nvars, hard_clauses, soft_clauses, timeout=240, solver_name='cd19'):\n    \"\"\"Naive core-guided solver — excludes all core literals. Fast but suboptimal.\"\"\"\n    soft_lits = []\n    for w, clause in soft_clauses:\n        if len(clause) != 1:\n            return None, None\n        soft_lits.append((w, clause[0]))\n\n    soft_lits.sort(key=lambda x: x[0], reverse=True)\n    t0 = time.time()\n\n    with Solver(name=solver_name) as sat:\n        for clause in hard_clauses:\n            sat.add_clause(clause)\n\n        excluded = set()\n        best_sol = None\n        best_cost = float('inf')\n\n        while time.time() - t0 < timeout:\n            assumptions = [lit for _, lit in soft_lits if lit not in excluded]\n            remaining = max(1, int(timeout - (time.time() - t0)))\n            try:\n                result = sat_solve_with_timeout(sat, assumptions=assumptions, timeout=remaining)\n            except SolverTimeout:\n                break\n            if result:\n                model = sat.get_model()\n                sol = [lit for lit in model if abs(lit) <= nvars]\n                present = set(abs(lit) for lit in sol)\n                for v in range(1, nvars + 1):\n                    if v not in present:\n                        sol.append(v)\n                cost = evaluate_cost(sol, soft_clauses)\n                if cost < best_cost:\n                    best_cost = cost\n                    best_sol = sol\n                break\n            else:\n                core = sat.get_core()\n                if not core:\n                    break\n                excluded.update(core)\n\n    return best_sol, best_cost\n\n\ndef core_guided_budget(nvars, hard_clauses, soft_clauses, timeout=60,\n                       solver_name='cd19', conf_budget=100000):\n    \"\"\"Core-guided solver with conflict budget — handles hard SAT instances.\n\n    When a SAT call exceeds the conflict budget, drops the lightest remaining\n    assumption instead of hanging. This is dramatically more effective than\n    naive core-guided on instances where some SAT calls hang (e.g. synplicate).\n\n    Game-changer results:\n    - synplicate size11 arity3/f3: 535→194 (4.25x→1.54x)\n    - synplicate dag_run2_16: 819→333 (2.06x→0.84x, BEATS REFERENCE)\n    \"\"\"\n    soft_lits = []\n    for w, clause in soft_clauses:\n        if len(clause) != 1:\n            return None, None\n        soft_lits.append((w, clause[0]))\n\n    soft_lits.sort(key=lambda x: x[0], reverse=True)\n    t0 = time.time()\n\n    with Solver(name=solver_name) as sat:\n        for clause in hard_clauses:\n            sat.add_clause(clause)\n\n        excluded = set()\n        best_sol = None\n        best_cost = float('inf')\n\n        for iteration in range(len(soft_lits) * 2):\n            if time.time() - t0 > timeout:\n                break\n            assumptions = [lit for _, lit in soft_lits if lit not in excluded]\n            if not assumptions:\n                break\n\n            sat.conf_budget(conf_budget)\n            result = sat.solve_limited(assumptions=assumptions, expect_interrupt=True)\n\n            if result is True:\n                model = sat.get_model()\n                sol = [lit for lit in model if abs(lit) <= nvars]\n                present = set(abs(lit) for lit in sol)\n                for v in range(1, nvars + 1):\n                    if v not in present:\n                        sol.append(v)\n                cost = evaluate_cost(sol, soft_clauses)\n                if cost < best_cost:\n                    best_cost = cost\n                    best_sol = sol\n                break\n            elif result is False:\n                core = sat.get_core()\n                if not core:\n                    break\n                excluded.update(core)\n            else:\n                # Budget exceeded — drop lightest remaining assumption\n                remaining = [(w, lit) for w, lit in soft_lits if lit not in excluded]\n                if not remaining:\n                    break\n                _, lightest = min(remaining, key=lambda x: x[0])\n                excluded.add(lightest)\n\n    return best_sol, best_cost\n\n\ndef wpm1_solve(nvars, hard_clauses, soft_clauses, timeout=240, solver_name='cd19'):\n    \"\"\"WPM1-style core-guided solver with proper relaxation variables.\n\n    Instead of excluding all core literals (naive approach), adds relaxation:\n    - For each core, find min weight and subtract from all core members\n    - Add at-most-one relaxation constraint\n    - Zero-weight assumptions are removed\n\n    Much better quality than naive core-guided, especially for weighted instances.\n    \"\"\"\n    soft_lits = []\n    for w, clause in soft_clauses:\n        if len(clause) != 1:\n            return None, None\n        soft_lits.append((w, clause[0]))\n\n    t0 = time.time()\n    next_var = nvars + 1\n\n    with Solver(name=solver_name) as sat:\n        for clause in hard_clauses:\n            sat.add_clause(clause)\n\n        # Active assumptions: {assumption_lit: weight}\n        active = {}\n        for w, lit in soft_lits:\n            if lit in active:\n                active[lit] = active[lit] + w\n            else:\n                active[lit] = w\n\n        lower_bound = 0\n        best_sol = None\n        best_cost = float('inf')\n        iterations = 0\n\n        while time.time() - t0 < timeout:\n            iterations += 1\n            assumptions = list(active.keys())\n\n            if sat.solve(assumptions=assumptions):\n                model = sat.get_model()\n                sol = [lit for lit in model if abs(lit) <= nvars]\n                present = set(abs(lit) for lit in sol)\n                for v in range(1, nvars + 1):\n                    if v not in present:\n                        sol.append(v)\n                cost = evaluate_cost(sol, soft_clauses)\n                if cost < best_cost:\n                    best_cost = cost\n                    best_sol = sol\n                break\n            else:\n                core = sat.get_core()\n                if not core:\n                    break\n                core_set = set(core)\n\n                # Find minimum weight in core\n                min_w = min(active[lit] for lit in core if lit in active)\n                lower_bound += min_w\n\n                # Relaxation variables for this core\n                relax_vars = []\n                for lit in core:\n                    if lit not in active:\n                        continue\n                    w = active[lit]\n                    del active[lit]\n\n                    remaining_w = w - min_w\n                    if remaining_w > 0:\n                        # Split: keep original lit with remaining weight\n                        active[lit] = remaining_w\n\n                    # Create relaxation variable\n                    r = next_var\n                    next_var += 1\n                    relax_vars.append(r)\n\n                    # lit OR r must be true (if lit is falsified, r must be true)\n                    sat.add_clause([lit, r])\n\n                # At most one relaxation variable can be true (exactly one lit in core is relaxed)\n                # Encode as: at-least-one + pairwise at-most-one\n                if len(relax_vars) > 1:\n                    # At least one relaxation (the core says at least one assumption must be false)\n                    sat.add_clause(relax_vars)\n                    # Pairwise at-most-one (for small cores)\n                    if len(relax_vars) <= 20:\n                        for i in range(len(relax_vars)):\n                            for j in range(i + 1, len(relax_vars)):\n                                sat.add_clause([-relax_vars[i], -relax_vars[j]])\n                    else:\n                        # For large cores, use sequential counter encoding\n                        _encode_at_most_one_sequential(sat, relax_vars, next_var)\n                        next_var += len(relax_vars) - 1\n                elif len(relax_vars) == 1:\n                    sat.add_clause(relax_vars)\n\n    return best_sol, best_cost\n\n\ndef _encode_at_most_one_sequential(sat, lits, start_var):\n    \"\"\"Encode at-most-one constraint using sequential counter (linear clauses).\"\"\"\n    n = len(lits)\n    if n <= 1:\n        return\n    # Auxiliary vars: s_1, ..., s_{n-1}\n    s = [start_var + i for i in range(n - 1)]\n    # x_0 => s_0\n    sat.add_clause([-lits[0], s[0]])\n    for i in range(1, n - 1):\n        # x_i => s_i\n        sat.add_clause([-lits[i], s[i]])\n        # s_{i-1} => s_i\n        sat.add_clause([-s[i - 1], s[i]])\n        # x_i and s_{i-1} can't both be true\n        sat.add_clause([-lits[i], -s[i - 1]])\n    # x_{n-1} and s_{n-2} can't both be true\n    sat.add_clause([-lits[n - 1], -s[n - 2]])\n","numLines":255,"startLine":1,"totalLines":255}}}
