5: break\n    \n    t1 = time.time()\n    best_this = current_best\n    \n    for trial in range(15):\n        if time.time() - t1 > budget:\n            break\n        \n        sn = random.choice(['cd19', 'g4'])\n        \n        try:\n            with Solver(name=sn) as sat:\n                for clause in hards:\n                    sat.add_clause(clause)\n                \n                selectors = []\n                for i, (w, clause) in enumerate(softs):\n                    sel = nvars + 1 + i\n                    selectors.append(sel)\n                    sat.add_clause([-sel] + clause)\n                \n                order = list(range(nsoft))\n                random.shuffle(order)\n                \n                must_satisfy = []\n                for idx in order:\n                    if time.time() - t1 > budget:\n                        break\n                    assumptions = must_satisfy + [selectors[idx]]\n                    if sat.solve(assumptions=assumptions):\n                        must_satisfy.append(selectors[idx])\n                \n                if sat.solve(assumptions=must_satisfy):\n                    model = sat.get_model()\n                    sol = [lit for lit in model if abs(lit) <= nvars]\n                    present = set(abs(lit) for lit in sol)\n                    for v in range(1, nvars+1):\n                        if v not in present:\n                            sol.append(v)\n                    cost = evaluate_cost(sol, softs)\n                    \n                    if cost < best_this:\n                        viol = check_hard_clauses(sol, hards)\n                        if not viol:\n                            best_this = cost\n                            update_solution(inst, cost, sol, f'rnd-greedy-{sn}')\n                            print(f\"  Trial {trial}({sn}): {cost} ({cost/ref:.2f}x)\", flush=True)\n        except:\n            pass\n    \n    print(f\"  Final: {best_this} ({best_this/ref:.2f}x)\", flush=True)\n    del data; gc.collect()\n    \n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {short} | approach: rnd-greedy-ext | cost: {best_this} | time: {time.time()-t1:.1f} | notes: extended rnd-greedy\\n\")\n\nprint(f\"\\nTotal time: {time.time()-t0:.0f}s\", flush=True)\nPYEOF","description":"Extended randomized greedy on high-ratio instances","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":233,"cache_read_input_tokens":165475,"cache_creation":{"ephemeral_5m_input_tokens":233,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"2cd38268-3020-4fa6-8469-5e6f8588d856"}
