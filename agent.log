reedy SAT...\")\nsol, cost = greedy_sat(nvars, hards, softs, timeout=120, solver_name='cd19')\nif sol and cost < current_best:\n    print(f\"Greedy SAT: {cost}\")\n    if update_solution(inst, cost, sol, \"greedy-sat-cd19\"):\n        current_best = cost\n\n# Multi-init with more trials\nremaining = 260 - (time.time() - t0)\nif remaining > 20:\n    print(f\"Multi-init ({remaining:.0f}s)...\")\n    sol, cost = multi_init(nvars, hards, softs, timeout=remaining-5, max_trials=1000)\n    if sol and cost < current_best:\n        print(f\"Multi-init: {cost}\")\n        if update_solution(inst, cost, sol, \"multi-init-1000\"):\n            current_best = cost\n\nprint(f\"Done: best={current_best} in {time.time()-t0:.1f}s\")\nwith open('/tmp/agent-sat-1/experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: greedy+multi-init | cost: {current_best} | time: {time.time()-t0:.1f} | notes: decision-tree improvement\\n\")\nPYEOF\n\ncat > /tmp/solve_synplicate.py << 'PYEOF'\n\"\"\"Core-guided budget + greedy on synplicate instances with ratio > 1.5x\"\"\"\nimport sys, time, signal\nsys.path.insert(0, '/tmp/agent-sat-1')\nsignal.alarm(280)\n\nfrom library.wcnf_parser import parse_wcnf\nfrom library.solvers import greedy_sat\nfrom library.solutions import update_solution, get_best_costs\nfrom library.core_guided import core_guided_budget, wpm1_solve\n\nbase = \"benchmarks/max-sat-2024/mse24-anytime-weighted/\"\ninstances = {\n    0: \"synplicate_new-synplicate_synthetic_dag_run2_12_size_8_ms_26_50_0_erm.wcnf\",\n    1: \"synplicate_new-synplicate_synthetic_dag_run2_13_size_11_ms_26_50_0_erm.wcnf\",\n    2: \"synplicate_new-synplicate_synthetic_dag_run2_10_size_11_ms_26_50_0_erm.wcnf\",\n    3: \"synplicate_new-synplicate_synthetic_dag_run1_14_size_6_ms_0_25_0_erm.wcnf\",\n    4: \"synplicate_new-synplicate_synthetic_dag_run1_14_size_5_ms_0_25_0_erm.wcnf\",\n    5: \"synplicate_new-synplicate_synthetic_dag_run2_17_size_10_ms_26_50_0_erm.wcnf\",\n    6: \"synplicate_new-synplicate_synthetic_dag_run1_16_size_4_ms_0_25_0_erm.wcnf\",\n    7: \"synplicate_new-synplicate_synthetic_dag_run1_17_size_5_ms_0_25_0_erm.wcnf\",\n    8: \"synplicate_new-synplicate_complete_tree_arity3_feature_3_size_11_ms_0_25_0_erm.wcnf\",\n    9: \"synplicate_new-synplicate_synthetic_dag_run2_0_size_10_ms_26_50_0_erm.wcnf\",\n}\n\nidx = int(sys.argv[1])\ninst = instances[idx]\nprint(f\"Working on {inst}\")\nt0 = time.time()\n\ndata = parse_wcnf(base + inst)\nnvars = data['nvars']\nhards = data['hard_clauses']\nsofts = data['soft_clauses']\nprint(f\"nvars={nvars}, nhards={len(hards)}, nsofts={len(softs)}\")\n\ncosts = get_best_costs()\ncurrent_best = costs.get(inst, float('inf'))\nprint(f\"Current best: {current_best}\")\n\nunit_softs = all(len(cl) == 1 for _, cl in softs)\n\n# Core-guided budget with various budgets\nfor budget in [50000, 100000, 200000, 500000]:\n    remaining = 260 - (time.time() - t0)\n    if remaining < 20:\n        break\n    if unit_softs:\n        sol, cost = core_guided_budget(nvars, hards, softs, timeout=min(60, remaining-5), \n                                        solver_name='cd19', conf_budget=budget)\n        if sol and cost is not None and cost < current_best:\n            print(f\"Core-guided budget={budget}: {cost}\")\n            if update_solution(inst, cost, sol, f\"core-guided-budget-{budget}\"):\n                current_best = cost\n\n# WPM1\nif unit_softs:\n    remaining = 260 - (time.time() - t0)\n    if remaining > 30:\n        sol, cost = wpm1_solve(nvars, hards, softs, timeout=min(90, remaining-5), solver_name='cd19')\n        if sol and cost is not None and cost < current_best:\n            print(f\"WPM1: {cost}\")\n            if update_solution(inst, cost, sol, \"wpm1-cd19\"):\n                current_best = cost\n\n# Greedy SAT\nremaining = 260 - (time.time() - t0)\nif remaining > 30 and len(softs) < 500:\n    sol, cost = greedy_sat(nvars, hards, softs, timeout=remaining-5, solver_name='cd19')\n    if sol and cost is not None and cost < current_best:\n        print(f\"Greedy: {cost}\")\n        if update_solution(inst, cost, sol, \"greedy-cd19\"):\n            current_best = cost\n\nprint(f\"Done: best={current_best} in {time.time()-t0:.1f}s\")\nwith open('/tmp/agent-sat-1/experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: core-guided+wpm1+greedy | cost: {current_best} | time: {time.time()-t0:.1f} | notes: synplicate improvement\\n\")\nPYEOF\n\ncat > /tmp/solve_parametric.py << 'PYEOF'\n\"\"\"CWLS + walksat on ParametricRBAC domino instances\"\"\"\nimport sys, time, signal\nsys.path.insert(0, '/tmp/agent-sat-1')\nsignal.alarm(280)\n\nfrom library.wcnf_parser import parse_wcnf\nfrom library.solvers import build_occurrence_lists, walksat_soft, assignment_to_lits\nfrom library.clause_weight_ls import clause_weight_local_search\nfrom library.solutions import update_solution, load_solutions\n\nbase = \"benchmarks/max-sat-2024/mse24-anytime-weighted/\"\ninstances = {\n    0: \"ParametricRBACMaintenance_mse20_wt-role_domino_multiple_0.1_1.wcnf\",\n    1: \"ParametricRBACMaintenance_mse20_wt-role_domino_multiple_0.7_7.wcnf\",\n    2: \"ParametricRBACMaintenance_mse20_wt-role_domino_multiple_0.3_1.wcnf\",\n    3: \"ParametricRBACMaintenance_mse20_wt-role_domino_multiple_0.3_9.wcnf\",\n    4: \"ParametricRBACMaintenance_mse20_wt-role_domino_multiple_0.5_7.wcnf\",\n    5: \"ParametricRBACMaintenance_mse20_wt-role_domino_multiple_0.7_0.wcnf\",\n    6: \"ParametricRBACMaintenance_mse20_wt-role_domino_multiple_0.4_1.wcnf\",\n    7: \"ParametricRBACMaintenance_mse20_wt-role_domino_multiple_0.5_6.wcnf\",\n    8: \"ParametricRBACMaintenance_mse20_wt-role_domino_multiple_0.4_0.wcnf\",\n}\n\nidx = int(sys.argv[1])\ninst = instances[idx]\nprint(f\"Working on {inst}\")\nt0 = time.time()\n\ndata = parse_wcnf(base + inst)\nnvars = data['nvars']\nhards = data['hard_clauses']\nsofts = data['soft_clauses']\nprint(f\"nvars={nvars}, nhards={len(hards)}, nsofts={len(softs)}\")\n\nsolutions = load_solutions()\nif inst not in solutions:\n    print(\"No existing solution!\")\n    sys.exit(1)\n\ncurrent_best = solutions[inst]['cost']\nconfig = solutions[inst]['configuration']\nprint(f\"Starting from cost={current_best}\")\n\nassignment = bytearray(nvars + 1)\nfor lit in config:\n    v = abs(lit)\n    if v <= nvars:\n        assignment[v] = 1 if lit > 0 else 0\n\nocc = build_occurrence_lists(nvars, hards, softs)\n\n# Alternate CWLS and walksat-soft\nfor round_num in range(4):\n    remaining = 260 - (time.time() - t0)\n    if remaining < 30:\n        break\n    \n    round_time = min(remaining - 10, 60)\n    print(f\"Round {round_num}: CWLS ({round_time:.0f}s)...\")\n    best_assign, best_cost = clause_weight_local_search(\n        assignment, softs, hards, occ, timeout=round_time, smooth_probability=0.005\n    )\n    if best_cost < current_best:\n        lits = assignment_to_lits(best_assign)\n        if update_solution(inst, best_cost, lits, f\"cwls-r{round_num}\"):\n            current_best = best_cost\n            assignment = bytearray(best_assign)\n            print(f\"  -> {best_cost}\")\n    \n    remaining = 260 - (time.time() - t0)\n    if remaining < 30:\n        break\n    round_time = min(remaining - 10, 60)\n    print(f\"Round {round_num}: walksat-soft ({round_time:.0f}s)...\")\n    best_assign2, best_cost2 = walksat_soft(assignment, softs, hards, occ, timeout=round_time)\n    if best_cost2 < current_best:\n        lits = assignment_to_lits(best_assign2)\n        if update_solution(inst, best_cost2, lits, f\"walksat-r{round_num}\"):\n            current_best = best_cost2\n            assignment = bytearray(best_assign2)\n            print(f\"  -> {best_cost2}\")\n\nprint(f\"Done: best={current_best} in {time.time()-t0:.1f}s\")\nwith open('/tmp/agent-sat-1/experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: cwls+walksat | cost: {current_best} | time: {time.time()-t0:.1f} | notes: parametric improvement\\n\")\nPYEOF\necho \"All scripts ready\"","description":"Write solver scripts for decision-tree, synplicate, parametric"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":734,"cache_read_input_tokens":64531,"cache_creation":{"ephemeral_5m_input_tokens":734,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"38135602-62e8-4094-9f41-0f1fb730f536","uuid":"64b7f94f-2e0e-4ad7-ad51-752bc208d8b9"}
