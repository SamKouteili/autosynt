rrent_best = full_cost\n            print(f\"  -> NEW BEST: {full_cost} ({full_cost/ref:.2f}x)\")\n    else:\n        print(f\"  Greedy failed (UNSAT with heavy-as-hard?)\")\n        # Maybe some heavy softs can't all be satisfied - try without\n        sol2, cost2 = greedy_sat(nvars, hards, softs, timeout=45, solver_name='cd19')\n        if sol2 and cost2 is not None and cost2 < current_best:\n            update_solution(inst, cost2, sol2, \"greedy-cd19\")\n            current_best = cost2\n            print(f\"  -> Fallback greedy: {cost2}\")\n    \n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: heavy-as-hard greedy | cost: {current_best} | time: {time.time()-t0:.1f} | notes: timetabling heavy-as-hard\\n\")\nPYEOF","description":"Heavy-as-hard strategy on timetabling","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":807,"cache_read_input_tokens":97723,"cache_creation":{"ephemeral_5m_input_tokens":807,"ephemeral_1h_input_tokens":0},"output_tokens":10,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"38135602-62e8-4094-9f41-0f1fb730f536","uuid":"18927ace-7c09-4a52-96bf-ddb327e88df2"}
