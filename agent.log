   break\n    \n    # Try multi-init first for new diverse starting points\n    t1 = time.time()\n    sol, cost = multi_init(nvars, hards, softs, timeout=remaining//2, max_trials=500)\n    print(f\"  Multi-init: cost={cost} ({time.time()-t1:.1f}s)\")\n    \n    if sol and cost < current_best:\n        viol = check_hard_clauses(sol, hards)\n        if not viol:\n            update_solution(inst, cost, sol, 'multi-init')\n            current_best = cost\n            config = sol\n            print(f\"    IMPROVED to {cost}\")\n    \n    # Now try CWLS from best known\n    if config:\n        assignment = bytearray(nvars + 1)\n        for lit in config:\n            v = abs(lit)\n            if v <= nvars:\n                assignment[v] = 1 if lit > 0 else 0\n        \n        occ = build_occurrence_lists(nvars, hards, softs)\n        remaining2 = min(30, int(260 - (time.time()-t0)))\n        if remaining2 > 5:\n            t1 = time.time()\n            best_assign, best_cost = clause_weight_local_search(\n                assignment, softs, hards, occ, timeout=remaining2\n            )\n            print(f\"  CWLS: cost={best_cost} ({time.time()-t1:.1f}s)\")\n            \n            if best_cost < current_best:\n                sol_lits = assignment_to_lits(best_assign)\n                viol = check_hard_clauses(sol_lits, hards)\n                if not viol:\n                    update_solution(inst, best_cost, sol_lits, 'cwls-from-best')\n                    print(f\"    IMPROVED: {current_best} -> {best_cost}\")\n                    current_best = best_cost\n    \n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst[:60]} | approach: multi-init+cwls | cost: {current_best} | time: {time.time()-t0:.1f} | notes: dt improvement\\n\")\nPYEOF\necho \"decision-tree script ready\"","description":"Write decision-tree improvement script"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"us