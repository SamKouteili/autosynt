"'\"'PYEOF'\"'\"' import sys, time, signal sys.path.insert(0, '\"'\"'/tmp/agent-sat-1'\"'\"') from library.wcnf_parser import parse_wcnf, evaluate_cost from library.solutions import update_solution, get_best_costs from library.solvers import sat_solve_with_timeout, SolverTimeout from pysat.solvers import Solver  base = \"benchmarks/max-sat-2024/mse24-anytime-weighted/\"  for inst in [\"lisbon-wedding_wt-lisbon-wedding-3-18.wcnf\", \"lisbon-wedding_wt-lisbon-wedding-1-19.wcnf\"]:     print(f\"\\n=== {inst} ===\")     t0 = time.time()          data = parse_wcnf(base + inst)     nvars, hards, softs = data['\"'\"'nvars'\"'\"'], data['\"'\"'hard_clauses'\"'\"'], data['\"'\"'soft_clauses'\"'\"']     print(f\"nvars={nvars}, nhards={len(hards)}, nsofts={len(softs)}\")          costs = get_best_costs()     current_best = costs.get(inst, float('\"'\"'inf'\"'\"'))     print(f\"Current: {current_best}\")          # Protected greedy SAT with per-call timeout     nsoft = len(softs)     with Solver(name='\"'\"'cd19'\"'\"') as sat:         for clause in hards:             sat.add_clause(clause)                  selectors = []         for i, (w, clause) in enumerate(softs):             sel = nvars + 1 + i             selectors.append(sel)             sat.add_clause([-sel] + clause)                  indexed = sorted(range(nsoft), key=lambda i: softs[i][0], reverse=True)                  must_satisfy = []         best_model = None         best_cost = float('\"'\"'inf'\"'\"')                  # Initial solve with timeout         try:             if sat_solve_with_timeout(sat, timeout=30):                 model = sat.get_model()                 true_lits = set(model)                 cost = sum(w for w, cl in softs if not any(lit in true_lits for lit in cl))                 if cost < best_cost:                     best_cost = cost                     best_model = model                     print(f\"  Initial: {cost}\")         except SolverTimeout:             print(\"  Initial solve timeout\")                  for idx in indexed:             if time.time() - t0 > 240:                 break             assumptions = must_satisfy + [selectors[idx]]             try:                 if sat_solve_with_timeout(sat, assumptions=assumptions, timeout=10):                     must_satisfy.append(selectors[idx])                     model = sat.get_model()                     true_lits = set(model)                     cost = sum(w for w, cl in softs if not any(lit in true_lits for lit in cl))                     if cost < best_cost:                         best_cost = cost                         best_model = model                 else:                     pass  # UNSAT with this assumption, skip             except SolverTimeout:                 pass  # Skip this soft clause if SAT call times out                  if best_model is not None:             solution = [lit for lit in best_model if abs(lit) <= nvars]             present = set(abs(lit) for lit in solution)             for v in range(1, nvars + 1):                 if v not in present:                     solution.append(v)             full_cost = evaluate_cost(solution, softs)             print(f\"  Final cost: {full_cost}\")             if full_cost < current_best:                 update_solution(inst, full_cost, solution, \"greedy-protected\")                 current_best = full_cost                 print(f\"  -> NEW BEST: {full_cost}\")          print(f\"  Done in {time.time()-t0:.1f}s, best={current_best}\")     with open('\"'\"'experiments.log'\"'\"', '\"'\"'a'\"'\"') as f:         f.write(f\"[{time.strftime('\"'\"'%Y-%m-%d %H:%M:%S'\"'\"')}] instance: {inst} | approach: greedy-protected | cost: {current_best} | time: {time.time()-t0:.1f} | notes: lisbon unsolved protected\\n\") PYEOF' && pwd -P >| /tmp/claude-1a6f-cwd\n---\nec2-user   82798  0.0  0.0 223112  3476 ?        Ss   04:16   0:00 /bin/bash -c source /home/ec2-user/.claude/shell-snapshots/snapshot-bash-1773634141508-07t3is.sh && shopt -u