9'\"'\"')             if sol and cost is not None:                 print(f\"    Cost: {cost} ({cost/ref:.2f}x)\")                 if update_solution(inst, cost, sol, '\"'\"'greedy-cd19'\"'\"'):                     print(f\"    NEW BEST!\")                     improved = True             del sol, cost          # Strategy 2: Multi-init (good for most instances)     if nvars < 1000000:         from library.solvers import multi_init         remaining = min(40, approach_timeout - (time.time() - t0))         if remaining > 5:             print(f\"  Multi-init ({remaining:.0f}s)...\")             sol, cost = multi_init(nvars, hc, sc, timeout=remaining, max_trials=500)             if sol and cost is not None:                 print(f\"    Cost: {cost} ({cost/ref:.2f}x)\")                 if update_solution(inst, cost, sol, '\"'\"'multi-init'\"'\"'):                     print(f\"    NEW BEST!\")                     improved = True             del sol, cost          # Strategy 3: Core-guided budget (for unit softs)     if unit_softs > 10 and unit_softs == nsofts and nvars < 500000:         from library.core_guided import core_guided_budget         remaining = min(60, approach_timeout - (time.time() - t0))         if remaining > 10:             print(f\"  Core-guided-budget ({remaining:.0f}s)...\")             sol, cost = core_guided_budget(nvars, hc, sc, timeout=remaining, conf_budget=200000)             if sol and cost is not None:                 print(f\"    Cost: {cost} ({cost/ref:.2f}x)\")                 if update_solution(inst, cost, sol, '\"'\"'core-guided-budget'\"'\"'):                     print(f\"    NEW BEST!\")                     improved = True             del sol, cost          # Strategy 4: Tabu/CWLS from existing best     sols_data = load_solutions()     if inst in sols_data and nvars < 500000:         from library.solvers import build_occurrence_lists, tabu_search, assignment_to_lits         from library.clause_weight_ls import clause_weight_local_search                  config = sols_data[inst]['\"'\"'configuration'\"'\"']         assign = bytearray(nvars + 1)         for lit in config:             v = abs(lit)             if v <= nvars:                 assign[v] = 1 if lit > 0 else 0         del sols_data, config         gc.collect()                  occ = build_occurrence_lists(nvars, hc, sc)                  remaining = min(80, approach_timeout - (time.time() - t0))         if remaining > 10:             print(f\"  CWLS ({remaining:.0f}s)...\")             ba, bc = clause_weight_local_search(assign, sc, hc, occ, timeout=remaining)             print(f\"    Cost: {bc} ({bc/ref:.2f}x)\")             if update_solution(inst, bc, assignment_to_lits(ba), '\"'\"'cwls'\"'\"'):                 print(f\"    NEW BEST!\")                 improved = True             assign = bytearray(ba)                  remaining = min(60, approach_timeout - (time.time() - t0))         if remaining > 10:             print(f\"  Tabu ({remaining:.0f}s)...\")             ba, bc = tabu_search(assign, sc, hc, occ, timeout=remaining, restarts=3, perturb_prob=0.05)             print(f\"    Cost: {bc} ({bc/ref:.2f}x)\")             if update_solution(inst, bc, assignment_to_lits(ba), '\"'\"'tabu'\"'\"'):                 print(f\"    NEW BEST!\")                 improved = True                  del assign, occ     else:         del sols_data          elapsed = time.time() - t0     best = get_best_costs().get(inst, '\"'\"'FAIL'\"'\"')     with open('\"'\"'experiments.log'\"'\"', '\"'\"'a'\"'\"') as f:         f.write(f\"[{time.strftime('\"'\"'%Y-%m-%d %H:%M:%S'\"'\"')}] instance: {inst} | approach: sequential-multi | cost: {best} | time: {elapsed:.1f} | notes: seq solver\\n\")          # Clean up     del d, hc, sc     gc.collect()          return improved  # Get all instances with ratio > 1.5 and < 1M vars, sorted by worst ratio ref = {} with open('\"'\"'benchmarks/max-sat-2024/best-costs.csv'\"'\"') as f:     reader = csv.reader(f)     next(reader)     for row in reader:         ref[row[0]] = int(row[1])  best = get_best_costs() targets = [] for inst, r in ref.items():     if r <= 0 or inst not in best:         continue     ratio = best[inst] / r     if ratio > 1.5:         targets.append((ratio, inst, r))  targets.sort(reverse=True)  script_start = time.time() total_improved = 0 for ratio, inst, r in targets:     if time.time() - script_start > 270:         break     # Skip huge instances     if '\"'\"'MinimumWeight'\"'\"' in inst or '\"'\"'pa-2'\"'\"' in inst or '\"'\"'pa-3'\"'\"' in inst:         continue     if '\"'\"'polysite-bloat'\"'\"' in inst:         continue  # Separate process          try:         if solve_instance(inst, r, approach_timeout=min(240, 280 - (time.time() - script_start))):             total_improved += 1     except Exception as e:         print(f\"  ERROR: {e}\")     gc.collect()  print(f\"\\n{'\"'\"'='\"'\"'*60}\") print(f\"Total improved: {total_improved}\") print(f\"Total time: {time.time()-script_start:.1f}s\") PYEOF python3 /tmp/solve_sequential.py 2>&1' && pwd -P >| /tmp/claude-8df7-cwd\nec2-user   82902  100  1.2 3511836 1183840 ?     Rl   04:16 120:53 python3 /tmp/solve_sequential.py\nec2-user   83666  0.0  0.0 223112  3488 ?        Ss   04:23   0:00 /bin/bash -c source /home/ec2-user/.claude/shell-snapshots/snapshot-bash-1773634147908-z18kx5.sh && shopt -u extglob 2>/dev/null || true && eval '# Run a quick targeted solver for the worst non-huge instances directly python3 -u << '\"'\"'PYEOF'\"'\"' import sys, time, os, gc sys.path.insert(0, '\"'\"'/tmp/agent-sat-2'\"'\"') os.chdir('\"'\"'/tmp/agent-sat-2'\"'\"')  from library.wcnf_parser import parse_wcnf, evaluate_cost from library.solutions import update_solution, get_best_costs, load_solutions from library.solvers import greedy_sat, multi_init, build_occurrence_lists, tabu_search, assignment_to_lits from library.clause_weight_ls import clause_weight_local_search from library.core_guided import core_guided_budget  # Target: 