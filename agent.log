r inst, ref in instances:\n    if time.time() - t0 > 270:\n        break\n    path = f'benchmarks/max-sat-2024/mse24-anytime-weighted/{inst}'\n    current_best = get_best_costs().get(inst, float('inf'))\n    ratio = current_best / ref if ref > 0 else 0\n    print(f\"\\n=== ...{inst[60:]} (cur={current_best}, ref={ref}, {ratio:.2f}x) ===\")\n    \n    data = parse_wcnf(path)\n    nvars = data['nvars']\n    hards = data['hard_clauses']\n    softs = data['soft_clauses']\n    \n    remaining = min(25, int(270 - (time.time()-t0)))\n    if remaining < 5: break\n    \n    # Multi-init with more trials\n    t1 = time.time()\n    sol, cost = multi_init(nvars, hards, softs, timeout=remaining//2, max_trials=1000)\n    print(f\"  Multi-init: cost={cost} ({time.time()-t1:.1f}s)\")\n    \n    if sol and cost < current_best:\n        viol = check_hard_clauses(sol, hards)\n        if not viol:\n            update_solution(inst, cost, sol, 'multi-init-1000')\n            current_best = cost\n            print(f\"    IMPROVED to {cost}\")\n    \n    # CWLS from best\n    sols = load_solutions()\n    if inst in sols:\n        config = sols[inst]['configuration']\n        assignment = bytearray(nvars + 1)\n        for lit in config:\n            v = abs(lit)\n            if v <= nvars:\n                assignment[v] = 1 if lit > 0 else 0\n        \n        occ = build_occurrence_lists(nvars, hards, softs)\n        remaining2 = min(15, int(270 - (time.time()-t0)))\n        if remaining2 > 3:\n            t1 = time.time()\n            best_assign, best_cost = clause_weight_local_search(\n                assignment, softs, hards, occ, timeout=remaining2\n            )\n            print(f\"  CWLS: cost={best_cost} ({time.time()-t1:.1f}s)\")\n            \n            if best_cost < current_best:\n                sol_lits = assignment_to_lits(best_assign)\n                viol = check_hard_clauses(sol_lits, hards)\n                if not viol:\n                    update_solution(inst, best_cost, sol_lits, 'cwls')\n                    current_best = best_cost\n                    print(f\"    IMPROVED to {best_cost}\")\n    \n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: ...{inst[60:80]} | approach: multi+cwls | cost: {current_best} | time: {time.time()-t0:.1f} | notes: dt v2\\n\")\nPYEOF\necho \"ready\"","description":"Write decision-tree v2 script"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":223,"cache_read_input_tokens":77584,"cache_creation":{"ephemeral_5m_input_tokens":223,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"08226073-5f90-4516-bbb0-385b966184c3"}
