{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_019CLJ47vQs6wHuN8VE6A6hZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015m42qzcNG2RaLs99XsXZMG","name":"Bash","input":{"command":"python3 << 'PYEOF'\n\"\"\"Haplotyping-13: split heavy (w=581) / light (w=1) and use core-guided + greedy on light.\"\"\"\nimport sys, time\nsys.path.insert(0, 'library')\nfrom wcnf_parser import parse_wcnf, check_hard_clauses, evaluate_cost\nfrom core_guided import core_guided_solve, core_guided_budget\nfrom solvers import greedy_sat\nfrom solutions import update_solution, get_best_costs\n\ninst = 'haplotyping-pedigrees_wt-ped2.G.recomb10-0.20-13.wcnf'\npath = f'benchmarks/max-sat-2024/mse24-anytime-weighted/{inst}'\n\nt0 = time.time()\ndata = parse_wcnf(path)\nnvars = data['nvars']\nhards = data['hard_clauses']\nsofts = data['soft_clauses']\n\ncurrent_best = get_best_costs().get(inst, float('inf'))\nprint(f\"cur={current_best}, ref=40755\")\n\n# Split: heavy (w=581) as hard, light (w=1) as soft\nheavy = [(w, c) for w, c in softs if w > 1]\nlight = [(w, c) for w, c in softs if w == 1]\nprint(f\"Heavy: {len(heavy)} (w={heavy[0][0] if heavy else '?'}), Light: {len(light)}\")\n\naugmented_hards = hards + [c for _, c in heavy]\nprint(f\"Augmented hard clauses: {len(augmented_hards)}\")\n\n# Check if light clauses are unit\nunit = all(len(c)==1 for _,c in light)\nprint(f\"Light clauses unit: {unit}\")\n\nif unit:\n    # Core-guided on light clauses\n    print(\"\\nCore-guided on light clauses (120s)...\")\n    t1 = time.time()\n    sol, cost_light = core_guided_solve(nvars, augmented_hards, light, timeout=120, solver_name='cd19')\n    elapsed = time.time() - t1\n    print(f\"Core-guided(light): cost={cost_light}, time={elapsed:.1f}s\")\n    \n    if sol:\n        actual_cost = evaluate_cost(sol, softs)\n        viol = check_hard_clauses(sol, hards)\n        print(f\"Actual cost: {actual_cost}, violations: {len(viol)}\")\n        if not viol and actual_cost < current_best:\n            update_solution(inst, actual_cost, sol, 'core-guided-split-heavy')\n            current_best = actual_cost\n            print(f\"IMPROVED to {actual_cost}\")\n\n# Also try greedy SAT on light clauses\nremaining = int(270 - (time.time() - t0))\nif remaining > 20:\n    print(f\"\\nGreedy SAT on light clauses ({remaining}s)...\")\n    t1 = time.time()\n    sol2, cost2 = greedy_sat(nvars, augmented_hards, light, timeout=remaining, solver_name='cd19')\n    elapsed = time.time() - t1\n    print(f\"Greedy-SAT(light): cost={cost2}, time={elapsed:.1f}s\")\n    \n    if sol2:\n        actual_cost2 = evaluate_cost(sol2, softs)\n        viol2 = check_hard_clauses(sol2, hards)\n        print(f\"Actual cost: {actual_cost2}, violations: {len(viol2)}\")\n        if not viol2 and actual_cost2 < current_best:\n            update_solution(inst, actual_cost2, sol2, 'greedy-sat-split-heavy')\n            current_best = actual_cost2\n            print(f\"IMPROVED to {actual_cost2}\")\n\nwith open('experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: split-heavy | cost: {current_best} | time: {time.time()-t0:.1f} | notes: haplo-13 split heavy/light\\n\")\nPYEOF","description":"Run split-heavy approach on haplotyping-13","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3329,"cache_read_input_tokens":98082,"cache_creation":{"ephemeral_5m_input_tokens":3329,"ephemeral_1h_input_tokens":0},"output_tokens":11,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"51cad18e-44a7-4d8a-8427-3a1cdb520812"}
