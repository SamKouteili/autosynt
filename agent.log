{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UKp3VZMSqSjd32DhcUHSAh","type":"tool_result","content":"     1→\"\"\"Compressed storage for best solutions. Bit-packs configurations + lzma for ~1200x compression.\"\"\"\n     2→\n     3→import gzip\n     4→import json\n     5→import lzma\n     6→from datetime import datetime, timezone\n     7→from pathlib import Path\n     8→\n     9→import numpy as np\n    10→\n    11→SOLUTIONS_FILE = Path(__file__).resolve().parent.parent / \"best-solutions.bin\"\n    12→\n    13→\n    14→def load_solutions() -> dict:\n    15→    \"\"\"Load best solutions from compressed binary file.\n    16→\n    17→    Returns dict: {instance_name: {cost, configuration, method, timestamp}}\n    18→    where configuration is a list of signed literals [1, -2, 3, ...].\n    19→    Returns empty dict if file doesn't exist.\n    20→    \"\"\"\n    21→    if not SOLUTIONS_FILE.exists():\n    22→        return {}\n    23→\n    24→    data = SOLUTIONS_FILE.read_bytes()\n    25→\n    26→    # Format: 4 bytes meta length (big endian) | gzip meta json | lzma packed bits\n    27→    meta_len = int.from_bytes(data[:4], \"big\")\n    28→    meta = json.loads(gzip.decompress(data[4 : 4 + meta_len]))\n    29→    packed = np.frombuffer(lzma.decompress(data[4 + meta_len :]), dtype=np.uint8)\n    30→    bits = np.unpackbits(packed)\n    31→\n    32→    result = {}\n    33→    for name, info in meta.items():\n    34→        offset, length = info[\"offset\"], info[\"length\"]\n    35→        signs = bits[offset : offset + length]\n    36→        config = [(i + 1) if s else -(i + 1) for i, s in enumerate(signs)]\n    37→        result[name] = {\n    38→            \"cost\": info[\"cost\"],\n    39→            \"configuration\": config,\n    40→            \"method\": info.get(\"method\", \"\"),\n    41→            \"timestamp\": info.get(\"timestamp\", \"\"),\n    42→        }\n    43→    return result\n    44→\n    45→\n    46→def save_solutions(solutions: dict) -> None:\n    47→    \"\"\"Save all solutions to compressed binary file.\"\"\"\n    48→    meta = {}\n    49→    all_signs = []\n    50→    for name, sol in solutions.items():\n    51→        config = sol[\"configuration\"]\n    52→        signs = [1 if x > 0 else 0 for x in config]\n    53→        meta[name] = {\n    54→            \"cost\": sol[\"cost\"],\n    55→            \"offset\": len(all_signs),\n    56→            \"length\": len(config),\n    57→            \"method\": sol.get(\"method\", \"\"),\n    58→            \"timestamp\": sol.get(\"timestamp\", \"\"),\n    59→        }\n    60→        all_signs.extend(signs)\n    61→\n    62→    packed = np.packbits(np.array(all_signs, dtype=np.uint8)).tobytes()\n    63→    meta_gz = gzip.compress(json.dumps(meta).encode(), compresslevel=9)\n    64→    bits_lzma = lzma.compress(packed, preset=9)\n    65→\n    66→    SOLUTIONS_FILE.write_bytes(\n    67→        len(meta_gz).to_bytes(4, \"big\") + meta_gz + bits_lzma\n    68→    )\n    69→\n    70→\n    71→def update_solution(instance: str, cost: int, configuration: list[int], method: str) -> bool:\n    72→    \"\"\"Update solution for an instance if it improves on the current best.\n    73→\n    74→    Returns True if the solution was updated (new best found).\n    75→    \"\"\"\n    76→    solutions = load_solutions()\n    77→    current = solutions.get(instance)\n    78→    if current is not None and current[\"cost\"] <= cost:\n    79→        return False\n    80→\n    81→    solutions[instance] = {\n    82→        \"cost\": cost,\n    83→        \"configuration\": configuration,\n    84→        \"method\": method,\n    85→        \"timestamp\": datetime.now(timezone.utc).strftime(\"%Y-%m-%dT%H:%M:%SZ\"),\n    86→    }\n    87→    save_solutions(solutions)\n    88→    return True\n    89→\n    90→\n    91→def get_best_costs() -> dict[str, int]:\n    92→    \"\"\"Return {instance_name: best_cost} for all solved instances.\"\"\"\n    93→    if not SOLUTIONS_FILE.exists():\n    94→        return {}\n    95→    data = SOLUTIONS_FILE.read_bytes()\n    96→    meta_len = int.from_bytes(data[:4], \"big\")\n    97→    meta = json.loads(gzip.decompress(data[4 : 4 + meta_len]))\n    98→    return {name: info[\"cost\"] for name, info in meta.items()}\n    99→"}]},"parent_tool_use_id":null,"session_id":"38135602-62e8-4094-9f41-0f1fb730f536","uuid":"5317118e-99aa-4b93-9d36-ef9dcebc5183","tool_use_result":{"type":"text","file":{"filePath":"/tmp/agent-sat-1/library/solutions.py","content":"\"\"\"Compressed storage for best solutions. Bit-packs configurations + lzma for ~1200x compression.\"\"\"\n\nimport gzip\nimport json\nimport lzma\nfrom datetime import datetime, timezone\nfrom pathlib import Path\n\nimport numpy as np\n\nSOLUTIONS_FILE = Path(__file__).resolve().parent.parent / \"best-solutions.bin\"\n\n\ndef load_solutions() -> dict:\n    \"\"\"Load best solutions from compressed binary file.\n\n    Returns dict: {instance_name: {cost, configuration, method, timestamp}}\n    where configuration is a list of signed literals [1, -2, 3, ...].\n    Returns empty dict if file doesn't exist.\n    \"\"\"\n    if not SOLUTIONS_FILE.exists():\n        return {}\n\n    data = SOLUTIONS_FILE.read_bytes()\n\n    # Format: 4 bytes meta length (big endian) | gzip meta json | lzma packed bits\n    meta_len = int.from_bytes(data[:4], \"big\")\n    meta = json.loads(gzip.decompress(data[4 : 4 + meta_len]))\n    packed = np.frombuffer(lzma.decompress(data[4 + meta_len :]), dtype=np.uint8)\n    bits = np.unpackbits(packed)\n\n    result = {}\n    for name, info in meta.items():\n        offset, length = info[\"offset\"], info[\"length\"]\n        signs = bits[offset : offset + length]\n        config = [(i + 1) if s else -(i + 1) for i, s in enumerate(signs)]\n        result[name] = {\n            \"cost\": info[\"cost\"],\n            \"configuration\": config,\n            \"method\": info.get(\"method\", \"\"),\n            \"timestamp\": info.get(\"timestamp\", \"\"),\n        }\n    return result\n\n\ndef save_solutions(solutions: dict) -> None:\n    \"\"\"Save all solutions to compressed binary file.\"\"\"\n    meta = {}\n    all_signs = []\n    for name, sol in solutions.items():\n        config = sol[\"configuration\"]\n        signs = [1 if x > 0 else 0 for x in config]\n        meta[name] = {\n            \"cost\": sol[\"cost\"],\n            \"offset\": len(all_signs),\n            \"length\": len(config),\n            \"method\": sol.get(\"method\", \"\"),\n            \"timestamp\": sol.get(\"timestamp\", \"\"),\n        }\n        all_signs.extend(signs)\n\n    packed = np.packbits(np.array(all_signs, dtype=np.uint8)).tobytes()\n    meta_gz = gzip.compress(json.dumps(meta).encode(), compresslevel=9)\n    bits_lzma = lzma.compress(packed, preset=9)\n\n    SOLUTIONS_FILE.write_bytes(\n        len(meta_gz).to_bytes(4, \"big\") + meta_gz + bits_lzma\n    )\n\n\ndef update_solution(instance: str, cost: int, configuration: list[int], method: str) -> bool:\n    \"\"\"Update solution for an instance if it improves on the current best.\n\n    Returns True if the solution was updated (new best found).\n    \"\"\"\n    solutions = load_solutions()\n    current = solutions.get(instance)\n    if current is not None and current[\"cost\"] <= cost:\n        return False\n\n    solutions[instance] = {\n        \"cost\": cost,\n        \"configuration\": configuration,\n        \"method\": method,\n        \"timestamp\": datetime.now(timezone.utc).strftime(\"%Y-%m-%dT%H:%M:%SZ\"),\n    }\n    save_solutions(solutions)\n    return True\n\n\ndef get_best_costs() -> dict[str, int]:\n    \"\"\"Return {instance_name: best_cost} for all solved instances.\"\"\"\n    if not SOLUTIONS_FILE.exists():\n        return {}\n    data = SOLUTIONS_FILE.read_bytes()\n    meta_len = int.from_bytes(data[:4], \"big\")\n    meta = json.loads(gzip.decompress(data[4 : 4 + meta_len]))\n    return {name: info[\"cost\"] for name, info in meta.items()}\n","numLines":99,"startLine":1,"totalLines":99}}}
