lect()\n        continue\n    \n    weights = Counter(w for w, _ in softs)\n    if len(weights) < 2:\n        del data; gc.collect()\n        continue\n    \n    sorted_w = sorted(weights.keys())\n    min_w, max_w = sorted_w[0], sorted_w[-1]\n    if max_w < min_w * 3:\n        del data; gc.collect()\n        continue\n    \n    heavy = [(w, cl) for w, cl in softs if w > min_w * 2]\n    if len(heavy) < 5 or len(heavy) > 20000:\n        del data; gc.collect()\n        continue\n    \n    current_best = costs[inst]\n    sys.stdout.write(f\"  Trying {inst[:50]}... \")\n    sys.stdout.flush()\n    \n    remaining = min(25, 250 - (time.time() - t_global))\n    sol, cost = wpm1_solve(nvars, hards, heavy, timeout=remaining, solver_name='cd19')\n    if sol and cost is not None:\n        full_cost = evaluate_cost(sol, softs)\n        if full_cost < current_best:\n            update_solution(inst, full_cost, sol, \"wpm1-heavy\")\n            print(f\"IMPROVED {current_best}->{full_cost} ({full_cost/ref:.2f}x)\")\n            improved += 1\n        else:\n            print(f\"no improvement ({full_cost} vs {current_best})\")\n    else:\n        print(\"timeout/no solution\")\n    \n    del data; gc.collect()\n\nprint(f\"\\nImproved: {improved}, Time: {time.time()-t_global:.1f}s\")\nPYEOF","description":"Direct bimodal sweep (foreground)","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":154,"cache_read_input_tokens":180227,"cache_creation":{"ephemeral_5m_input_tokens":154,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"38135602-62e8-4094-9f41-0f1fb730f536","uuid":"3dfb3f26-b81e-4015-8731-8f2a3f8c37c7"}
