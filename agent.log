           mark_unrealizable(inst, \"ltlsynt+decompose\")\n                solved += 1\n                print(f\"  [U] {inst} ({ni}i/{no}o) [{elapsed:.1f}s]\", flush=True)\n                ts = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n                with open(EXPERIMENTS_LOG, \"a\") as f:\n                    f.write(f\"[{ts}] instance: {inst} | approach: ltlsynt+decompose | status: unrealizable | and_gates: N/A | time: {elapsed:.1f}s | notes: newly-solvable\\n\")\n            elif \"REALIZABLE\" in output and \"UNREALIZABLE\" not in output:\n                parts = output.split(\"\\n\", 1)\n                aiger = parts[1] if len(parts) > 1 else None\n                gates = -1\n                if aiger:\n                    try: gates = int(aiger.strip().split('\\n')[0].split()[5])\n                    except: pass\n                update_solution(inst, 'realizable', aiger, \"ltlsynt+decompose\")\n                solved += 1\n                print(f\"  [R] {inst}: {gates}g ({ni}i/{no}o) [{elapsed:.1f}s]\", flush=True)\n                ts = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n                with open(EXPERIMENTS_LOG, \"a\") as f:\n                    f.write(f\"[{ts}] instance: {inst} | approach: ltlsynt+decompose | status: realizable | and_gates: {gates} | time: {elapsed:.1f}s | notes: newly-solvable\\n\")\n            continue\n        \n        ins = subprocess.run([\"syfco\", \"-ins\", tlsf], capture_output=True, text=True, timeout=10).stdout.strip()\n        outs = subprocess.run([\"syfco\", \"-outs\", tlsf], capture_output=True, text=True, timeout=10).stdout.strip()\n        simplified = subprocess.run([\"ltlfilt\", \"--simplify\", \"--remove-wm\"],\n                                   input=formula, capture_output=True, text=True, timeout=10).stdout.strip()\n        use_formula = simplified if simplified else formula\n        \n        for algos, method in [\n            ([\"-f\", use_formula, f\"--ins={ins}\", f\"--outs={outs}\", \"--aiger=both+ud+dc\", \"--decompose=yes\"], \"ltlsynt-simplified\"),\n            ([\"-f\", use_formula, f\"--ins={ins}\", f\"--outs={outs}\", \"--aiger=both+ud+dc\", \"--algo=sd\", \"--decompose=yes\"], \"ltlsynt-simplified+sd\"),\n        ]:\n            try:\n                proc = subprocess.run([\"ltlsynt\"] + algos, capture_output=True, text=True, timeout=60)\n                output = proc.stdout.strip()\n                elapsed = time.time() - t0\n                if \"UNREALIZABLE\" in output:\n                    mark_unrealizable(inst, method)\n                    solved += 1\n                    print(f\"  [U] {inst} ({ni}i/{no}o) [{elapsed:.1f}s]\", flush=True)\n                    ts = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n                    with open(EXPERIMENTS_LOG, \"a\") as f:\n                        f.write(f\"[{ts}] instance: {inst} | approach: {method} | status: unrealizable | and_gates: N/A | time: {elapsed:.1f}s | notes: newly-solvable\\n\")\n                    break\n                elif \"REALIZABLE\" in output and \"UNREALIZABLE\" not in output:\n                    parts = output.split(\"\\n\", 1)\n                    aiger = parts[1] if len(parts) > 1 else None\n                    gates = -1\n                    if aiger:\n                        try: gates = int(aiger.strip().split('\\n')[0].split()[5])\n                        except: pass\n                    update_solution(inst, 'realizable', aiger, method)\n                    solved += 1\n                    print(f\"  [R] {inst}: {gates}g ({ni}i/{no}o) [{elapsed:.1f}s]\", flush=True)\n                    ts = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n                    with open(EXPERIMENTS_LOG, \"a\") as f:\n                        f.write(f\"[{ts}] instance: {inst} | approach: {method} | status: realizable | and_gates: {gates} | time: {elapsed:.1f}s | notes: newly-solvable\\n\")\n                    break\n            except subprocess.TimeoutExpired:\n            