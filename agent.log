udget on just unit softs\n    unit_only = [(softs[i][0], softs[i][1]) for i in unit_softs]\n    print(f\"\\nCore-guided on {len(unit_only)} unit softs only (120s)...\")\n    t1 = time.time()\n    sol, cost = core_guided_budget(nvars, hards, unit_only, timeout=120, solver_name='cd19', conf_budget=200000)\n    elapsed = time.time() - t1\n    print(f\"Core-guided(unit): cost={cost}, time={elapsed:.1f}s\")\n    \n    if sol:\n        actual_cost = evaluate_cost(sol, softs)\n        viol = check_hard_clauses(sol, hards)\n        print(f\"Actual cost (all softs): {actual_cost}, violations: {len(viol)}\")\n        if not viol and actual_cost < current_best:\n            update_solution(inst, actual_cost, sol, 'core-guided-unit-only')\n            current_best = actual_cost\n            print(f\"IMPROVED to {actual_cost}\")\n    \n    # Also try greedy SAT on all softs (19K softs, each call might be fast)\n    remaining = int(270 - (time.time() - t0))\n    if remaining > 30:\n        from solvers import greedy_sat\n        print(f\"\\nGreedy SAT on all {len(softs)} softs ({remaining}s)...\")\n        t1 = time.time()\n        sol2, cost2 = greedy_sat(nvars, hards, softs, timeout=remaining, solver_name='cd19')\n        elapsed = time.time() - t1\n        print(f\"Greedy-SAT: cost={cost2}, time={elapsed:.1f}s\")\n        if sol2 and cost2 and cost2 < current_best:\n            viol = check_hard_clauses(sol2, hards)\n            if not viol:\n                update_solution(inst, cost2, sol2, 'greedy-sat-cd19')\n                print(f\"IMPROVED to {cost2}\")\n\nwith open('experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: core-guided-analysis | cost: {current_best} | time: {time.time()-t0:.1f} | notes: haplo-13 structure analysis\\n\")\nPYEOF","description":"Analyze and try core-guided on haplotyping-13","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1