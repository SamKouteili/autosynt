{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_017JRcP1XxwzEbg6ybcaZq9n","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01B9NmGAM78imof7HsGLUd84","name":"Bash","input":{"command":"python3 -u << 'PYEOF'\n\"\"\"Targeted randomized greedy with multiple solver backends on decision-tree instances.\"\"\"\nimport sys, time, random\nsys.path.insert(0, 'library')\nfrom wcnf_parser import parse_wcnf, check_hard_clauses, evaluate_cost\nfrom solutions import update_solution, get_best_costs\nfrom pysat.solvers import Solver\n\ninstances = [\n    ('decision-tree-primary-tumor-un-formula_0.8_2021_atleast_127_max-6_reduced_incomplete_adaboost_4.wcnf', 77),\n    ('decision-tree-tic-tac-toe-un-formula_0.8_2021_atleast_127_max-6_reduced_incomplete_adaboost_3.wcnf', 149),\n    ('decision-tree-tic-tac-toe-un-formula_0.8_2021_atleast_127_max-6_reduced_incomplete_adaboost_5.wcnf', 259),\n    ('decision-tree-australian-credit-un-formula_0.8_2021_atleast_63_max-5_reduced_incomplete_adaboost_3.wcnf', 186),\n]\n\nt0 = time.time()\nfor inst, ref in instances:\n    if time.time() - t0 > 260:\n        break\n    \n    path = f'benchmarks/max-sat-2024/mse24-anytime-weighted/{inst}'\n    data = parse_wcnf(path)\n    nvars = data['nvars']\n    hards = data['hard_clauses']\n    softs = data['soft_clauses']\n    nsoft = len(softs)\n    \n    current_best = get_best_costs().get(inst, float('inf'))\n    print(f\"\\n{inst.split('adaboost_')[1]} (cur={current_best}, ref={ref}, nsofts={nsoft})\", flush=True)\n    \n    budget = min(55, int(260 - (time.time()-t0)))\n    if budget < 10: break\n    \n    t1 = time.time()\n    for trial in range(20):\n        if time.time() - t1 > budget:\n            break\n        \n        solver_name = random.choice(['cd19', 'g4', 'cd15', 'mc'])\n        \n        try:\n            with Solver(name=solver_name) as sat:\n                for clause in hards:\n                    sat.add_clause(clause)\n                \n                selectors = []\n                for i, (w, clause) in enumerate(softs):\n                    sel = nvars + 1 + i\n                    selectors.append(sel)\n                    sat.add_clause([-sel] + clause)\n                \n                order = list(range(nsoft))\n                random.shuffle(order)\n                \n                must_satisfy = []\n                for idx in order:\n                    if time.time() - t1 > budget:\n                        break\n                    assumptions = must_satisfy + [selectors[idx]]\n                    if sat.solve(assumptions=assumptions):\n                        must_satisfy.append(selectors[idx])\n                \n                if sat.solve(assumptions=must_satisfy):\n                    model = sat.get_model()\n                    sol = [lit for lit in model if abs(lit) <= nvars]\n                    present = set(abs(lit) for lit in sol)\n                    for v in range(1, nvars+1):\n                        if v not in present:\n                            sol.append(v)\n                    cost = evaluate_cost(sol, softs)\n                    \n                    if cost < current_best:\n                        viol = check_hard_clauses(sol, hards)\n                        if not viol:\n                            current_best = cost\n                            update_solution(inst, cost, sol, f'rnd-greedy-{solver_name}')\n                            print(f\"  Trial {trial}({solver_name}): IMPROVED to {cost} ({cost/ref:.2f}x)\", flush=True)\n        except:\n            pass\n    \n    print(f\"  Final: {current_best} ({current_best/ref:.2f}x)\", flush=True)\n    \n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst.split('adaboost_')[1]} | approach: rnd-greedy-multi | cost: {current_best} | time: {time.time()-t1:.1f} | notes: dt rnd-greedy multi-solver\\n\")\nPYEOF","description":"Run randomized greedy with multiple solver backends on decision-tree","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1629,"cache_read_input_tokens":157254,"cache_creation":{"ephemeral_5m_input_tokens":1629,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"77e3e9c4-05cf-48d2-b8e8-9c1c269525af"}
