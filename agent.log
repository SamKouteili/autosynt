ht distribution\n    weights = Counter(w for w, _ in softs)\n    sorted_w = sorted(weights.keys())\n    min_w = sorted_w[0]\n    \n    # Heavy: anything more than 2x the minimum weight\n    heavy = [(w, cl) for w, cl in softs if w > min_w * 2]\n    \n    if not heavy:\n        del data\n        gc.collect()\n        continue\n    \n    print(f\"\\n{inst[:55]}: cur={current_best} ({current_best/ref:.2f}x)\")\n    print(f\"  All softs: {len(softs)}, Heavy: {len(heavy)}\")\n    \n    # WPM1 on heavy\n    remaining = min(50, 260 - (time.time() - t_global))\n    if remaining < 10:\n        break\n    sol, cost = wpm1_solve(nvars, hards, heavy, timeout=remaining, solver_name='cd19')\n    if sol and cost is not None:\n        full_cost = evaluate_cost(sol, softs)\n        print(f\"  WPM1 heavy={cost}, full={full_cost}\")\n        if full_cost < current_best:\n            update_solution(inst, full_cost, sol, \"wpm1-heavy\")\n            current_best = full_cost\n            print(f\"  -> NEW BEST! ({full_cost/ref:.2f}x)\")\n    else:\n        # Fallback: core-guided budget on heavy\n        remaining = min(30, 260 - (time.time() - t_global))\n        if remaining > 5:\n            sol2, cost2 = core_guided_budget(nvars, hards, heavy, timeout=remaining,\n                                              solver_name='cd19', conf_budget=300000)\n            if sol2 and cost2 is not None:\n                full_cost = evaluate_cost(sol2, softs)\n                print(f\"  Core-guided heavy={cost2}, full={full_cost}\")\n                if full_cost < current_best:\n                    update_solution(inst, full_cost, sol2, \"core-guided-heavy\")\n                    current_best = full_cost\n                    print(f\"  -> NEW BEST!\")\n    \n    del data\n    gc.collect()\n    \n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: wpm1-heavy | cost: {current_best} | time: {time.time()-t0:.1f} | notes: 