lution(inst, actual_cost, sol, 'core-guided-split-heavy')\n        current_best = actual_cost\n        print(f\"IMPROVED to {actual_cost}\")\n\n# Also try core_guided_budget on light clauses\nif time.time() - t0 < 220:\n    remaining = int(250 - (time.time() - t0))\n    print(f\"\\nCore-guided-budget on light clauses ({remaining}s)...\")\n    for budget in [200000, 1000000]:\n        if time.time() - t0 > 250:\n            break\n        t1 = time.time()\n        sol2, cost2 = core_guided_budget(nvars, augmented_hards, light, \n                                          timeout=min(60, int(250-(time.time()-t0))),\n                                          solver_name='cd19', conf_budget=budget)\n        print(f\"Budget({budget}): cost={cost2} ({time.time()-t1:.1f}s)\")\n        if sol2:\n            actual_cost2 = evaluate_cost(sol2, softs)\n            viol2 = check_hard_clauses(sol2, hards)\n            print(f\"  Actual cost: {actual_cost2}, violations: {len(viol2)}\")\n            if not viol2 and actual_cost2 < current_best:\n                update_solution(inst, actual_cost2, sol2, f'cgb-split-{budget}')\n                current_best = actual_cost2\n                print(f\"  IMPROVED to {actual_cost2}\")\n\nwith open('experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: split-heavy-core-guided | cost: {current_best} | time: {time.time()-t0:.1f} | notes: polysite-bloat split heavy/light\\n\")\nPYEOF","description":"Run split heavy/light approach on polysite-bloat","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1595,"cache_read_input_tokens":87629,"cache_creation":{"ephemeral_5m_input_tokens":1595,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"b