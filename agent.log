ds = data['hard_clauses']\n    softs = data['soft_clauses']\n    \n    assignment = bytearray(nvars + 1)\n    for lit in config:\n        v = abs(lit)\n        if v <= nvars:\n            assignment[v] = 1 if lit > 0 else 0\n    \n    occ = build_occurrence_lists(nvars, hards, softs)\n    \n    remaining = min(25, int(260 - (time.time()-t0)))\n    if remaining < 5:\n        break\n    \n    # Alternating: walksat-soft then CWLS\n    t1 = time.time()\n    best_assign, best_cost = walksat_soft(assignment, softs, hards, occ, timeout=remaining//2)\n    print(f\"  Walksat-soft: {best_cost} ({time.time()-t1:.1f}s)\")\n    \n    if best_cost < current_best:\n        sol_lits = assignment_to_lits(best_assign)\n        viol = check_hard_clauses(sol_lits, hards)\n        if not viol:\n            update_solution(inst, best_cost, sol_lits, 'walksat-soft')\n            current_best = best_cost\n            assignment = bytearray(best_assign)\n    \n    remaining2 = min(15, int(260 - (time.time()-t0)))\n    if remaining2 > 3:\n        t1 = time.time()\n        best_assign2, best_cost2 = clause_weight_local_search(\n            assignment, softs, hards, occ, timeout=remaining2\n        )\n        print(f\"  CWLS: {best_cost2} ({time.time()-t1:.1f}s)\")\n        \n        if best_cost2 < current_best:\n            sol_lits = assignment_to_lits(best_assign2)\n            viol = check_hard_clauses(sol_lits, hards)\n            if not viol:\n                update_solution(inst, best_cost2, sol_lits, 'cwls')\n                print(f\"    IMPROVED: {current_best} -> {best_cost2}\")\n    \n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst.split('_wt-')[1][:40]} | approach: walksat+cwls | cost: {min(best_cost, best_cost2 if 'best_cost2' in dir() else float('inf'))} | time: {time.time()-t1:.1f} | notes: rbac domino\\n\")\nPYEOF\necho \"rbac domino script ready\"","description":"Write RBAC domino improvement script"},"ca