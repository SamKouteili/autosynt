fy):\n            model = sat.get_model()\n            sol = [lit for lit in model if abs(lit) <= nvars]\n            present = set(abs(lit) for lit in sol)\n            for v in range(1, nvars+1):\n                if v not in present:\n                    sol.append(v)\n            cost = evaluate_cost(sol, softs)\n            \n            if cost < best_cost:\n                viol = check_hard_clauses(sol, hards)\n                if not viol:\n                    best_cost = cost\n                    update_solution(inst, cost, sol, f'rnd-greedy-split-{trial}')\n                    print(f\"  Trial {trial}: IMPROVED to {cost}\", flush=True)\n    \n    elapsed = time.time() - t1\n    if trial % 5 == 4:\n        print(f\"  {trial+1} trials, best={best_cost}, sat_in={len(must_satisfy)}/{nlight} ({elapsed:.1f}s)\", flush=True)\n\nprint(f\"\\nFinal: {best_cost}\")\n\nwith open('experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: rnd-greedy-split | cost: {best_cost} | time: {time.time()-t0:.1f} | notes: polysite-bloat rnd greedy\\n\")\nPYEOF","description":"Randomized greedy on polysite-bloat light clauses","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5061,"cache_read_input_tokens":140012,"cache_creation":{"ephemeral_5m_input_tokens":5061,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"f8c91315-6244-481c-96fa-41ade4228b89"}
