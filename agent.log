{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E3w9enmgdRoDFYXKe6ZSym","type":"tool_result","content":"     1→\"\"\"SAT-based bounded synthesis: encode 'exists k-state controller?' as SAT.\"\"\"\n     2→\n     3→import time\n     4→from math import ceil, log2\n     5→\n     6→from pysat.solvers import Solver\n     7→from pysat.formula import CNF\n     8→\n     9→\n    10→def bounded_synth(automaton, inputs, outputs, k, solver_name=\"cd19\", timeout=60):\n    11→    \"\"\"Encode bounded synthesis as SAT and solve.\n    12→\n    13→    Checks if there exists a k-state Mealy machine that satisfies the spec\n    14→    given by the automaton (universal co-Buchi or parity).\n    15→\n    16→    Args:\n    17→        automaton: parsed HOA dict (from automata.parse_hoa)\n    18→        inputs: list of input signal names\n    19→        outputs: list of output signal names\n    20→        k: number of states to try\n    21→        solver_name: PySAT solver name ('cd19' for CaDiCaL, 'g4' for glucose4)\n    22→        timeout: seconds\n    23→\n    24→    Returns dict: {sat: bool, model: list or None, time: float, k: int}\n    25→    \"\"\"\n    26→    start = time.time()\n    27→    n_aut = automaton[\"n_states\"]\n    28→    n_in = len(inputs)\n    29→    n_out = len(outputs)\n    30→\n    31→    # Variable allocation\n    32→    var_count = [0]\n    33→    def new_var():\n    34→        var_count[0] += 1\n    35→        return var_count[0]\n    36→\n    37→    # State variables: which automaton state maps to which controller state\n    38→    # lambda[q][s] = 1 iff automaton state q is associated with controller state s\n    39→    lam = [[new_var() for _ in range(k)] for _ in range(n_aut)]\n    40→\n    41→    # Transition function: delta[s][in_val] = s' (encoded in binary)\n    42→    # Output function: out[s][in_val][o] = bool\n    43→    state_bits = max(1, ceil(log2(k))) if k > 1 else 1\n    44→\n    45→    # delta[s][iv] = list of state_bits variables\n    46→    delta = {}\n    47→    for s in range(k):\n    48→        for iv in range(1 << n_in):\n    49→            delta[(s, iv)] = [new_var() for _ in range(state_bits)]\n    50→\n    51→    # output function: gamma[s][iv][o]\n    52→    gamma = {}\n    53→    for s in range(k):\n    54→        for iv in range(1 << n_in):\n    55→            gamma[(s, iv)] = [new_var() for _ in range(n_out)]\n    56→\n    57→    cnf = CNF()\n    58→\n    59→    # Initial state: automaton start states map to controller state 0\n    60→    for q0 in automaton[\"start\"]:\n    61→        cnf.append([lam[q0][0]])\n    62→\n    63→    # At least one controller state per automaton state in the annotation\n    64→    for q in range(n_aut):\n    65→        cnf.append(lam[q])  # At least one\n    66→\n    67→    # Consistency: transition relation\n    68→    # For each controller state s, input valuation iv, the output + next state\n    69→    # must be consistent with the automaton edges\n    70→\n    71→    # This is a simplified encoding. The agent should improve it.\n    72→    # For now, just encode basic reachability constraints.\n    73→\n    74→    elapsed = time.time() - start\n    75→\n    76→    # Solve\n    77→    with Solver(name=solver_name, bootstrap_with=cnf) as solver:\n    78→        remaining = timeout - elapsed\n    79→        if remaining <= 0:\n    80→            return {\"sat\": None, \"model\": None, \"time\": elapsed, \"k\": k}\n    81→\n    82→        # PySAT doesn't have native timeout for all solvers,\n    83→        # use propagation budget as approximate timeout\n    84→        sat = solver.solve()\n    85→        elapsed = time.time() - start\n    86→\n    87→        if sat:\n    88→            model = solver.get_model()\n    89→            return {\"sat\": True, \"model\": model, \"time\": elapsed, \"k\": k}\n    90→        else:\n    91→            return {\"sat\": False, \"model\": None, \"time\": elapsed, \"k\": k}\n    92→\n    93→\n    94→def iterative_bounded_synth(spec_automaton, inputs, outputs, max_k=64, timeout=300,\n    95→                             solver_name=\"cd19\"):\n    96→    \"\"\"Try bounded synthesis with increasing k until realizable or timeout.\n    97→\n    98→    Tries k = 1, 2, 4, 8, 16, 32, 64 (powers of 2).\n    99→\n   100→    Args:\n   101→        spec_automaton: parsed HOA dict\n   102→        inputs, outputs: signal name lists\n   103→        max_k: maximum number of states to try\n   104→        timeout: total timeout in seconds\n   105→        solver_name: PySAT solver name\n   106→\n   107→    Returns dict: {realizable: bool or None, k: int, model: list or None,\n   108→                   time: float, attempts: list}\n   109→    \"\"\"\n   110→    start = time.time()\n   111→    attempts = []\n   112→\n   113→    k = 1\n   114→    while k <= max_k:\n   115→        remaining = timeout - (time.time() - start)\n   116→        if remaining <= 0:\n   117→            break\n   118→\n   119→        per_k_timeout = int(min(remaining, max(10, remaining / 3)))\n   120→        result = bounded_synth(\n   121→            spec_automaton, inputs, outputs, k,\n   122→            solver_name=solver_name, timeout=per_k_timeout\n   123→        )\n   124→        attempts.append({\"k\": k, \"sat\": result[\"sat\"], \"time\": result[\"time\"]})\n   125→\n   126→        if result[\"sat\"]:\n   127→            return {\n   128→                \"realizable\": True,\n   129→                \"k\": k,\n   130→                \"model\": result[\"model\"],\n   131→                \"time\": time.time() - start,\n   132→                \"attempts\": attempts,\n   133→            }\n   134→\n   135→        k *= 2\n   136→\n   137→    return {\n   138→        \"realizable\": None,  # Could not determine within bounds/timeout\n   139→        \"k\": k // 2,\n   140→        \"model\": None,\n   141→        \"time\": time.time() - start,\n   142→        \"attempts\": attempts,\n   143→    }\n   144→"}]},"parent_tool_use_id":null,"session_id":"6882dd44-b12a-40ea-abce-8556d98170ba","uuid":"45998e0a-064d-4084-baef-cba9decdad64","timestamp":"2026-03-19T19:43:56.699Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/samkouteili/yale/rose/autosynt/library/bounded_synth.py","content":"\"\"\"SAT-based bounded synthesis: encode 'exists k-state controller?' as SAT.\"\"\"\n\nimport time\nfrom math import ceil, log2\n\nfrom pysat.solvers import Solver\nfrom pysat.formula import CNF\n\n\ndef bounded_synth(automaton, inputs, outputs, k, solver_name=\"cd19\", timeout=60):\n    \"\"\"Encode bounded synthesis as SAT and solve.\n\n    Checks if there exists a k-state Mealy machine that satisfies the spec\n    given by the automaton (universal co-Buchi or parity).\n\n    Args:\n        automaton: parsed HOA dict (from automata.parse_hoa)\n        inputs: list of input signal names\n        outputs: list of output signal names\n        k: number of states to try\n        solver_name: PySAT solver name ('cd19' for CaDiCaL, 'g4' for glucose4)\n        timeout: seconds\n\n    Returns dict: {sat: bool, model: list or None, time: float, k: int}\n    \"\"\"\n    start = time.time()\n    n_aut = automaton[\"n_states\"]\n    n_in = len(inputs)\n    n_out = len(outputs)\n\n    # Variable allocation\n    var_count = [0]\n    def new_var():\n        var_count[0] += 1\n        return var_count[0]\n\n    # State variables: which automaton state maps to which controller state\n    # lambda[q][s] = 1 iff automaton state q is associated with controller state s\n    lam = [[new_var() for _ in range(k)] for _ in range(n_aut)]\n\n    # Transition function: delta[s][in_val] = s' (encoded in binary)\n    # Output function: out[s][in_val][o] = bool\n    state_bits = max(1, ceil(log2(k))) if k > 1 else 1\n\n    # delta[s][iv] = list of state_bits variables\n    delta = {}\n    for s in range(k):\n        for iv in range(1 << n_in):\n            delta[(s, iv)] = [new_var() for _ in range(state_bits)]\n\n    # output function: gamma[s][iv][o]\n    gamma = {}\n    for s in range(k):\n        for iv in range(1 << n_in):\n            gamma[(s, iv)] = [new_var() for _ in range(n_out)]\n\n    cnf = CNF()\n\n    # Initial state: automaton start states map to controller state 0\n    for q0 in automaton[\"start\"]:\n        cnf.append([lam[q0][0]])\n\n    # At least one controller state per automaton state in the annotation\n    for q in range(n_aut):\n        cnf.append(lam[q])  # At least one\n\n    # Consistency: transition relation\n    # For each controller state s, input valuation iv, the output + next state\n    # must be consistent with the automaton edges\n\n    # This is a simplified encoding. The agent should improve it.\n    # For now, just encode basic reachability constraints.\n\n    elapsed = time.time() - start\n\n    # Solve\n    with Solver(name=solver_name, bootstrap_with=cnf) as solver:\n        remaining = timeout - elapsed\n        if remaining <= 0:\n            return {\"sat\": None, \"model\": None, \"time\": elapsed, \"k\": k}\n\n        # PySAT doesn't have native timeout for all solvers,\n        # use propagation budget as approximate timeout\n        sat = solver.solve()\n        elapsed = time.time() - start\n\n        if sat:\n            model = solver.get_model()\n            return {\"sat\": True, \"model\": model, \"time\": elapsed, \"k\": k}\n        else:\n            return {\"sat\": False, \"model\": None, \"time\": elapsed, \"k\": k}\n\n\ndef iterative_bounded_synth(spec_automaton, inputs, outputs, max_k=64, timeout=300,\n                             solver_name=\"cd19\"):\n    \"\"\"Try bounded synthesis with increasing k until realizable or timeout.\n\n    Tries k = 1, 2, 4, 8, 16, 32, 64 (powers of 2).\n\n    Args:\n        spec_automaton: parsed HOA dict\n        inputs, outputs: signal name lists\n        max_k: maximum number of states to try\n        timeout: total timeout in seconds\n        solver_name: PySAT solver name\n\n    Returns dict: {realizable: bool or None, k: int, model: list or None,\n                   time: float, attempts: list}\n    \"\"\"\n    start = time.time()\n    attempts = []\n\n    k = 1\n    while k <= max_k:\n        remaining = timeout - (time.time() - start)\n        if remaining <= 0:\n            break\n\n        per_k_timeout = int(min(remaining, max(10, remaining / 3)))\n        result = bounded_synth(\n            spec_automaton, inputs, outputs, k,\n            solver_name=solver_name, timeout=per_k_timeout\n        )\n        attempts.append({\"k\": k, \"sat\": result[\"sat\"], \"time\": result[\"time\"]})\n\n        if result[\"sat\"]:\n            return {\n                \"realizable\": True,\n                \"k\": k,\n                \"model\": result[\"model\"],\n                \"time\": time.time() - start,\n                \"attempts\": attempts,\n            }\n\n        k *= 2\n\n    return {\n        \"realizable\": None,  # Could not determine within bounds/timeout\n        \"k\": k // 2,\n        \"model\": None,\n        \"time\": time.time() - start,\n        \"attempts\": attempts,\n    }\n","numLines":144,"startLine":1,"totalLines":144}}}
