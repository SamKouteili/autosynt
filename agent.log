cost = evaluate_cost(lits, softs)\n    print(f\"  CWLS light={best_cost}, full={full_cost}\")\n    if full_cost < current_best:\n        update_solution(inst, full_cost, lits, \"cwls-heavy-hard\")\n        current_best = full_cost\n        print(f\"  -> NEW BEST: {full_cost}\")\n\nprint(f\"Done: best={current_best} in {time.time()-t0:.1f}s\")\nwith open('experiments.log', 'a') as f:\n    f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {inst} | approach: cwls-heavy-hard | cost: {current_best} | time: {time.time()-t0:.1f} | notes: polysite cwls\\n\")\nPYEOF","description":"CWLS on polysite-bloat from 204","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":726,"cache_read_input_tokens":92449,"cache_creation":{"ephemeral_5m_input_tokens":726,"ephemeral_1h_input_tokens":0},"output_tokens":25,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"38135602-62e8-4094-9f41-0f1fb730f536","uuid":"0253108d-aa86-4314-9fb4-5a9fb93e590f"}
