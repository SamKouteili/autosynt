tio:.2f}x)\", flush=True)\n    \n    assignment = bytearray(nvars + 1)\n    for lit in config:\n        v = abs(lit)\n        if v <= nvars:\n            assignment[v] = 1 if lit > 0 else 0\n    \n    occ = build_occurrence_lists(nvars, hards, softs)\n    \n    remaining = min(30, int(260 - (time.time()-t0)))\n    if remaining < 5: break\n    \n    t1 = time.time()\n    best_assign, best_cost = walksat_soft(assignment, softs, hards, occ, timeout=remaining)\n    print(f\"  Walksat-soft: {best_cost} ({time.time()-t1:.1f}s)\", flush=True)\n    \n    if best_cost < current_best:\n        sol_lits = assignment_to_lits(best_assign)\n        viol = check_hard_clauses(sol_lits, hards)\n        if not viol:\n            update_solution(inst, best_cost, sol_lits, 'walksat-soft')\n            print(f\"  IMPROVED: {current_best} -> {best_cost}\")\n    \n    del data, hards, softs, assignment, occ\n    gc.collect()\n    \n    with open('experiments.log', 'a') as f:\n        f.write(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] instance: {short} | approach: walksat-soft | cost: {best_cost} | time: {time.time()-t1:.1f} | notes: rbac domino\\n\")\n\nprint(f\"\\nDone in {time.time()-t0:.0f}s\", flush=True)\nPYEOF","description":"Run walksat-soft on ParametricRBAC domino","timeout":300000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":144047,"cache_read_input_tokens":8629,"cache_creation":{"ephemeral_5m_input_tokens":144047,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"8ed653bb-a3ea-4630-9552-a8c96528784c","uuid":"fc816c54-2dcb-4093-981e-78587ed29242"}
